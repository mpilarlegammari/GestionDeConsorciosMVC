                    <td><span class="status-badge warning">Pendiente de revisión</span></td>
                    <td><div class="table-actions"><a asp-controller="Pagos" asp-action="Details" asp-route-id="205">Ver detalle</a><a href="#">Ver comprobante</a></div></td>
                </tr>
                <tr>
                    <td>Abril 2026</td>
