@model IEnumerable<Pago>
@{
    ViewData["Title"] = "Mis Pagos";
    ViewData["Role"] = "Propietario";
}

@functions {
    private static string EstadoClass(EstadoPago estado) => estado switch
    {
        EstadoPago.Aprobado => "success",
        EstadoPago.PendienteRevision => "warning",
        EstadoPago.Rechazado => "danger",
        _ => "neutral"
    };
}

<section class="page-intro">
    <div>
        <h2>Mis Pagos</h2>
        <p>Consulta los pagos informados y su estado de revision.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Pagos" asp-action="InformarPago">Informar pago</a>
</section>

<section class="app-card filter-card" aria-label="Filtros de mis pagos">
    <form method="get" asp-action="MisPagos">
        <div class="form-grid">
            <div>
                <label class="form-label" for="mes">Mes</label>
                <select class="form-select" id="mes" name="mes">
                    <option value="">Todos</option>
                    <option value="5">Mayo</option>
                    <option value="4">Abril</option>
                    <option value="3">Marzo</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="anio">Anio</label>
                <select class="form-select" id="anio" name="anio">
                    <option>2026</option>
                    <option>2025</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="estado">Estado</label>
                <select class="form-select" id="estado" name="estado">
                    <option value="">Todos</option>
                    <option>Pendiente de revision</option>
                    <option>Aprobado</option>
                    <option>Rechazado</option>
                </select>
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
            </div>
        </div>
    </form>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Pagos informados</h3>
        <span class="status-badge">@Model.Count() registrados</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Periodo</th>
                    <th>Fecha de pago</th>
                    <th>Monto</th>
                    <th>Medio</th>
                    <th>Nro operacion</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7">Todavia no hay pagos informados.</td>
                    </tr>
                }
                else
                {
                    @foreach (var pago in Model)
                    {
                        <tr>
                            <td>@pago.Expensa.Periodo</td>
                            <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                            <td>@pago.MontoPagado.ToString("C")</td>
                            <td>@pago.MedioPago</td>
                            <td>@(string.IsNullOrWhiteSpace(pago.NumeroOperacion) ? "-" : pago.NumeroOperacion)</td>
                            <td><span class="status-badge @EstadoClass(pago.Estado)">@pago.Estado</span></td>
                            <td>
                                <div class="table-actions">
                                    <a asp-controller="Pagos" asp-action="Details" asp-route-id="@pago.Id">Ver detalle</a>
                                    @if (!string.IsNullOrWhiteSpace(pago.ComprobantePath))
                                    {
                                        <a href="@pago.ComprobantePath" target="_blank" rel="noopener">Ver comprobante</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
