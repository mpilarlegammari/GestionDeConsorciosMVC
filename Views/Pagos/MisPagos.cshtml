                    <td><div class="table-actions"><a asp-controller="Pagos" asp-action="Details" asp-route-id="203">Ver detalle</a><a href="#">Ver comprobante</a></div></td>
                </tr>
                <tr>
                    <td>Febrero 2026</td>
                    <td>15/03/2026</td>
