@{
    ViewData["Title"] = "Mis Pagos";
    ViewData["Role"] = "Propietario";
}

@* TODO backend: reemplazar datos mock por Model.Pagos. *@
@* TODO backend: obtener expensas pendientes del usuario autenticado. *@
@* TODO backend: asociar pago a ExpensaId. *@
@* TODO backend: validar permisos por propietario. *@

<section class="page-intro">
    <div>
        <h2>Mis Pagos</h2>
        <p>Consultá los pagos informados y su estado de revisión.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Pagos" asp-action="InformarPago">Informar pago</a>
</section>

<section class="dashboard-grid">
    <article class="app-card metric-card">
        <span>Pagos aprobados</span>
        <strong>8</strong>
        <small>En el año actual</small>
    </article>
    <article class="app-card metric-card">
        <span>Pagos pendientes</span>
        <strong>2</strong>
        <small>En revisión</small>
    </article>
    <article class="app-card metric-card">
        <span>Pagos rechazados</span>
        <strong>1</strong>
        <small>Requiere corrección</small>
    </article>
    <article class="app-card metric-card">
        <span>Último pago informado</span>
        <strong>12/05</strong>
        <small>$78.500</small>
    </article>
</section>

<section class="app-card filter-card" aria-label="Filtros de mis pagos">
    <form method="get" asp-action="MisPagos">
        <div class="form-grid">
            <div>
                <label class="form-label" for="mes">Mes</label>
                <select class="form-select" id="mes" name="mes">
                    <option value="">Todos</option>
                    <option value="5">Mayo</option>
                    <option value="4">Abril</option>
                    <option value="3">Marzo</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="anio">Año</label>
                <select class="form-select" id="anio" name="anio">
                    <option>2026</option>
                    <option>2025</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="estado">Estado</label>
                <select class="form-select" id="estado" name="estado">
                    <option value="">Todos</option>
                    <option>Pendiente de revisión</option>
                    <option>Aprobado</option>
                    <option>Rechazado</option>
                </select>
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
            </div>
        </div>
    </form>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Pagos informados</h3>
        <span class="status-badge">Datos mock</span>
    </div>
