@model PagosAdminIndexViewModel
@{
    ViewData["Title"] = "Pagos";
    ViewData["Role"] = "Administrador";
}

@functions {
    private static string EstadoClass(EstadoPago estado) => estado switch
    {
        EstadoPago.Aprobado => "success",
        EstadoPago.PendienteRevision => "warning",
        EstadoPago.Rechazado => "danger",
        _ => "neutral"
    };
}

@if (TempData["Success"] is string successMessage)
{
    <section class="form-alert show success" role="status">@successMessage</section>
}

<section class="page-intro">
    <div>
        <h2>Pagos</h2>
        <p>Revision administrativa de pagos informados por propietarios.</p>
    </div>
    <span class="status-badge">Backend</span>
</section>

<section class="dashboard-grid" aria-label="Resumen de pagos">
    <article class="app-card metric-card">
        <span>Pagos filtrados</span>
        <strong>@Model.CantidadPagos</strong>
        <small>Registros encontrados</small>
    </article>
    <article class="app-card metric-card">
        <span>Pendientes</span>
        <strong>@Model.Pendientes</strong>
        <small>Para revisar</small>
    </article>
    <article class="app-card metric-card">
        <span>Aprobados</span>
        <strong>@Model.Aprobados</strong>
        <small>Validados</small>
    </article>
    <article class="app-card metric-card">
        <span>Total informado</span>
        <strong>@Model.TotalInformado.ToString("C")</strong>
        <small>Monto reportado</small>
    </article>
</section>

<section class="app-card filter-card" aria-label="Filtros de pagos">
    <form method="get" asp-action="Index">
        <div class="form-grid">
            <div>
                <label class="form-label" for="estado">Estado</label>
                <select class="form-select" id="estado" name="estado">
                    <option value="">Todos</option>
                    @foreach (var estado in Enum.GetValues<EstadoPago>())
                    {
                        if (Model.Estado == estado)
                        {
                            <option value="@estado" selected>@estado</option>
                        }
                        else
                        {
                            <option value="@estado">@estado</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="consorcioId">Consorcio</label>
                <select class="form-select" id="consorcioId" name="consorcioId">
                    <option value="">Todos</option>
                    @foreach (var consorcio in Model.Consorcios)
                    {
                        if (Model.ConsorcioId == consorcio.Id)
                        {
                            <option value="@consorcio.Id" selected>@consorcio.Nombre</option>
                        }
                        else
                        {
                            <option value="@consorcio.Id">@consorcio.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="periodo">Periodo</label>
                <input class="form-control" id="periodo" name="periodo" type="month" value="@Model.Periodo" />
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
                <a class="btn btn-outline-secondary" asp-controller="Pagos" asp-action="Index">Limpiar</a>
            </div>
        </div>
    </form>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Pagos informados</h3>
        <span class="status-badge">@Model.CantidadPagos registrados</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Periodo</th>
                    <th>Consorcio</th>
                    <th>UF</th>
                    <th>Fecha pago</th>
                    <th>Monto</th>
                    <th>Medio</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Pagos.Any())
                {
                    <tr>
                        <td colspan="8">No hay pagos que coincidan con los filtros seleccionados.</td>
                    </tr>
                }
                else
                {
                    @foreach (var pago in Model.Pagos)
                    {
                        <tr>
                            <td>@pago.Expensa.Periodo</td>
                            <td>@pago.Expensa.UnidadFuncional.Consorcio.Nombre</td>
                            <td>@pago.Expensa.UnidadFuncional.NumeroUF</td>
                            <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                            <td>@pago.MontoPagado.ToString("C")</td>
                            <td>@pago.MedioPago</td>
                            <td><span class="status-badge @EstadoClass(pago.Estado)">@pago.Estado</span></td>
                            <td>
                                <div class="table-actions">
                                    <a asp-controller="Pagos" asp-action="Details" asp-route-id="@pago.Id">Ver detalle</a>
                                    @if (!string.IsNullOrWhiteSpace(pago.ComprobantePath))
                                    {
                                        <a href="@pago.ComprobantePath" target="_blank" rel="noopener">Ver comprobante</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
