@model PagoDetailsViewModel
@{
    ViewData["Title"] = "Detalle del Pago";
    ViewData["Role"] = Model.DetailRole;
}

@functions {
    private static string EstadoClass(EstadoPago estado) => estado switch
    {
        EstadoPago.Aprobado => "success",
        EstadoPago.PendienteRevision => "warning",
        EstadoPago.Rechazado => "danger",
        _ => "neutral"
    };

    private static string EstadoExpensaClass(EstadoExpensa estado) => estado switch
    {
        EstadoExpensa.Pagada => "success",
        EstadoExpensa.Pendiente => "warning",
        EstadoExpensa.Vencida => "danger",
        _ => "neutral"
    };
}

@if (TempData["Success"] is string successMessage)
{
    <section class="form-alert show success" role="status">@successMessage</section>
}

@if (TempData["Error"] is string errorMessage)
{
    <section class="form-alert show" role="alert">@errorMessage</section>
}

<section class="page-intro">
    <div>
        <h2>Detalle del Pago</h2>
        <p>Pago informado para la expensa @Model.Periodo.</p>
    </div>
    <span class="status-badge @EstadoClass(Model.Estado)">@Model.Estado</span>
</section>

<section class="dashboard-grid">
    <article class="app-card metric-card">
        <span>Monto pagado</span>
        <strong>@Model.MontoPagado.ToString("C")</strong>
        <small>Importe informado</small>
    </article>
    <article class="app-card metric-card">
        <span>Fecha de pago</span>
        <strong>@Model.FechaPago.ToString("dd/MM")</strong>
        <small>@Model.FechaPago.Year</small>
    </article>
    <article class="app-card metric-card">
        <span>Medio</span>
        <strong>@Model.MedioPago</strong>
        <small>@(string.IsNullOrWhiteSpace(Model.BancoEntidad) ? "Sin entidad" : Model.BancoEntidad)</small>
    </article>
    <article class="app-card metric-card">
        <span>Estado</span>
        <strong><span class="status-badge @EstadoClass(Model.Estado)">@Model.Estado</span></strong>
        <small>Registro del pago</small>
    </article>
</section>

<section class="content-grid section-card">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Datos generales</h3>
        </div>
        <dl class="detail-list">
            <div>
                <dt>Consorcio</dt>
                <dd>@Model.ConsorcioNombre</dd>
            </div>
            <div>
                <dt>Unidad funcional</dt>
                <dd>@Model.UnidadFuncionalNumero</dd>
            </div>
            <div>
                <dt>Propietario</dt>
                <dd>@Model.PropietarioNombre</dd>
            </div>
            <div>
                <dt>Email propietario</dt>
                <dd>@Model.PropietarioMail</dd>
            </div>
            <div>
                <dt>Periodo</dt>
                <dd>@Model.Periodo</dd>
            </div>
            <div>
                <dt>Monto expensa</dt>
                <dd>@Model.MontoExpensa.ToString("C")</dd>
            </div>
            <div>
                <dt>Estado expensa</dt>
                <dd><span class="status-badge @EstadoExpensaClass(Model.EstadoExpensa)">@Model.EstadoExpensa</span></dd>
            </div>
            <div>
                <dt>Fecha de pago</dt>
                <dd>@Model.FechaPago.ToString("dd/MM/yyyy")</dd>
            </div>
            <div>
                <dt>Monto pagado</dt>
                <dd>@Model.MontoPagado.ToString("C")</dd>
            </div>
            <div>
                <dt>Medio de pago</dt>
                <dd>@Model.MedioPago</dd>
            </div>
            <div>
                <dt>Numero de operacion</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.NumeroOperacion) ? "-" : Model.NumeroOperacion)</dd>
            </div>
            <div>
                <dt>Banco o entidad</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.BancoEntidad) ? "-" : Model.BancoEntidad)</dd>
            </div>
            <div class="detail-span-2">
                <dt>Comentarios</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Comentarios) ? "Sin comentarios." : Model.Comentarios)</dd>
            </div>
        </dl>
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Estado</h3>
        </div>
        <ul class="simple-list">
            <li>
                <span>Estado actual</span>
                <strong>@Model.Estado</strong>
            </li>
            <li>
                <span>Fecha de aprobacion</span>
                <strong>@(Model.FechaRevision.HasValue ? Model.FechaRevision.Value.ToString("dd/MM/yyyy HH:mm") : "Sin registro")</strong>
            </li>
            <li>
                <span>Observacion</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.ObservacionAdministracion) ? "Sin observaciones." : Model.ObservacionAdministracion)</strong>
            </li>
        </ul>
    </aside>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Comprobante</h3>
        <span class="status-badge">Archivo real</span>
    </div>
    <div class="detail-list">
        <div>
            <dt>Archivo</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.ComprobantePath) ? "Sin comprobante" : Model.ComprobantePath)</dd>
        </div>
        <div>
            <dt>Acciones</dt>
            <dd>
                @if (!string.IsNullOrWhiteSpace(Model.ComprobantePath))
                {
                    <span class="table-actions">
                        <a href="@Model.ComprobantePath" target="_blank" rel="noopener">Ver comprobante</a>
                        <a href="@Model.ComprobantePath" download>Descargar comprobante</a>
                    </span>
                }
                else
                {
                    <span>No hay comprobante adjunto.</span>
                }
            </dd>
        </div>
    </div>
</section>

<section class="app-card section-card">
    <div class="button-group">
        <a class="btn btn-outline-secondary" href="@Model.ReturnUrl">Volver</a>
        <a class="btn btn-primary" asp-controller="Expensas" asp-action="Details" asp-route-id="@Model.ExpensaId" asp-route-returnUrl="@Url.Action("Details", "Pagos", new { id = Model.Id })">Ver expensa asociada</a>
    </div>
</section>
