@{
    ViewData["Title"] = "Informar Pago";
    ViewData["Role"] = "Propietario";
    var expensas = ViewBag.Expensas as IEnumerable<Expensa> ?? Enumerable.Empty<Expensa>();
    var expensaActual = expensas.FirstOrDefault();
}

<section class="page-intro">
    <div>
        <h2>Informar Pago</h2>
        <p>Carga los datos del pago realizado para que la administracion lo revise.</p>
    </div>
    <span class="status-badge warning">Pendiente de revision</span>
</section>

@if (TempData["Error"] is string errorMessage)
{
    <section class="form-alert show" role="alert">@errorMessage</section>
}

@if (expensaActual is not null)
{
    <section class="app-card expense-card">
        <div>
            <span class="card-kicker">Consorcio</span>
            <h3>@expensaActual.UnidadFuncional.Consorcio.Nombre</h3>
            <p>Unidad funcional: @expensaActual.UnidadFuncional.NumeroUF</p>
        </div>
        <div class="expense-summary">
            <div>
                <span class="card-kicker">Periodo</span>
                <strong>@expensaActual.Periodo</strong>
            </div>
            <div>
                <span class="card-kicker">Monto a pagar</span>
                <strong>@expensaActual.MontoTotal.ToString("C")</strong>
            </div>
            <div>
                <span class="card-kicker">Vencimiento</span>
                <strong>@expensaActual.FechaVencimiento.ToString("dd/MM/yyyy")</strong>
            </div>
            <div>
                <span class="card-kicker">Estado</span>
                <strong><span class="status-badge warning">@expensaActual.Estado</span></strong>
            </div>
        </div>
        <a class="btn btn-outline-primary" asp-controller="Expensas" asp-action="Details" asp-route-id="@expensaActual.Id" asp-route-returnUrl="@Url.Action("InformarPago", "Pagos")">Ver detalle de expensa</a>
    </section>
}

<form asp-action="InformarPago" method="post" enctype="multipart/form-data" data-pago-form data-real-submit>
    @Html.AntiForgeryToken()
    <section class="app-card section-card">
        <div class="app-card-title">
            <h3>Datos del pago</h3>
            <span class="status-badge">Backend</span>
        </div>

        <div class="form-grid">
            <div>
                <label class="form-label" for="ExpensaId">Expensa / Periodo</label>
                <select class="form-select" id="ExpensaId" name="ExpensaId" data-pago-required>
                    <option value="">Seleccionar expensa</option>
                    @foreach (var expensa in expensas)
                    {
                        <option value="@expensa.Id">@expensa.Periodo - @expensa.UnidadFuncional.NumeroUF - @expensa.MontoTotal.ToString("C")</option>
                    }
                </select>
                <span class="field-validation" data-error-for="ExpensaId"></span>
            </div>
            <div>
                <label class="form-label" for="FechaPago">Fecha de pago</label>
                <input class="form-control" id="FechaPago" name="FechaPago" type="date" data-pago-required />
                <span class="field-validation" data-error-for="FechaPago"></span>
            </div>
            <div>
                <label class="form-label" for="MontoPagado">Monto pagado</label>
                <input class="form-control" id="MontoPagado" name="MontoPagado" type="number" min="1" step="0.01" placeholder="0.00" data-pago-monto />
                <span class="field-validation" data-error-for="MontoPagado"></span>
            </div>
            <div>
                <label class="form-label" for="MedioPago">Medio de pago</label>
                <select class="form-select" id="MedioPago" name="MedioPago" data-pago-required>
                    <option value="">Seleccionar medio</option>
                    <option>Transferencia bancaria</option>
                    <option>Deposito</option>
                    <option>Mercado Pago</option>
                    <option>Efectivo</option>
                    <option>Otro</option>
                </select>
                <span class="field-validation" data-error-for="MedioPago"></span>
            </div>
            <div>
                <label class="form-label" for="NumeroOperacion">Numero de operacion / referencia</label>
                <input class="form-control" id="NumeroOperacion" name="NumeroOperacion" type="text" placeholder="Ej: TRX-548921" />
            </div>
            <div>
                <label class="form-label" for="BancoEntidad">Banco o entidad</label>
                <input class="form-control" id="BancoEntidad" name="BancoEntidad" type="text" placeholder="Ej: Banco Nacion" />
            </div>
            <div class="form-span-2">
                <label class="form-label" for="ComprobantePago">Comprobante de pago</label>
                <input class="form-control" id="ComprobantePago" name="ComprobantePago" type="file" accept=".pdf,.jpg,.jpeg,.png" data-pago-file onchange="mostrarComprobanteSeleccionado(this)" />
                <span class="field-validation" data-error-for="ComprobantePago"></span>
                <div class="file-preview" data-payment-file-preview></div>
            </div>
            <div class="form-span-2">
                <label class="form-label" for="Comentarios">Comentarios opcionales</label>
                <textarea class="form-control" id="Comentarios" name="Comentarios" rows="4" placeholder="Podes agregar una aclaracion para la administracion."></textarea>
            </div>
        </div>

        <p class="form-note">El pago quedara pendiente de revision hasta que la administracion lo apruebe.</p>
        <div class="form-summary" data-pago-summary></div>

        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-controller="Pagos" asp-action="MisPagos">Cancelar</a>
            <button class="btn btn-primary" type="submit">Enviar pago para revision</button>
        </div>
    </section>
</form>
