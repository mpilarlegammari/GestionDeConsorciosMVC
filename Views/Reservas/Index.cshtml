@model ReservasAdminIndexViewModel

@{
    ViewData["Title"] = "Reservas";
    ViewData["Role"] = "Administrador";
}

@functions {
    private static string EstadoClass(EstadoReserva estado) => estado switch
    {
        EstadoReserva.Pendiente => "warning",
        EstadoReserva.Confirmada => "success",
        EstadoReserva.Cancelada => "danger",
        _ => "neutral"
    };
}

<section class="page-intro">
    <div>
        <h2>Reservas</h2>
        <p>Reservas de amenities realizadas por propietarios.</p>
    </div>
    <a class="btn btn-outline-primary" asp-controller="Amenities" asp-action="Index">Administrar amenities</a>
</section>

@if (TempData["Success"] is string successMessage)
{
    <section class="form-alert show success" role="status">@successMessage</section>
}

@if (TempData["Error"] is string errorMessage)
{
    <section class="form-alert show" role="alert">@errorMessage</section>
}

<section class="app-card filter-card" aria-label="Filtros de reservas">
    <form method="get" asp-action="Index">
        <div class="form-grid">
            <div>
                <label class="form-label" for="estado">Estado</label>
                <select class="form-select" id="estado" name="estado">
                    <option value="">Todos</option>
                    @foreach (var estado in Enum.GetValues<EstadoReserva>())
                    {
                        if (Model.Estado == estado)
                        {
                            <option value="@estado" selected>@estado</option>
                        }
                        else
                        {
                            <option value="@estado">@estado</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="consorcioId">Consorcio</label>
                <select class="form-select" id="consorcioId" name="consorcioId">
                    <option value="">Todos</option>
                    @foreach (var consorcio in Model.Consorcios)
                    {
                        if (Model.ConsorcioId == consorcio.Id)
                        {
                            <option value="@consorcio.Id" selected>@consorcio.Nombre</option>
                        }
                        else
                        {
                            <option value="@consorcio.Id">@consorcio.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="fecha">Fecha</label>
                <input class="form-control" id="fecha" name="fecha" type="date" value="@(Model.Fecha?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="form-span-2">
                <label class="form-label" for="busqueda">Buscar</label>
                <input class="form-control" id="busqueda" name="busqueda" value="@Model.Busqueda" type="search" placeholder="Amenity, UF, propietario u observacion" />
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Limpiar</a>
            </div>
        </div>
    </form>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Reservas registradas</h3>
        <span class="status-badge">Datos reales</span>
    </div>

    @if (Model.Reservas.Count == 0)
    {
        <p class="empty-state">No hay reservas para los filtros seleccionados.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-clean">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Horario</th>
                        <th>Consorcio</th>
                        <th>Amenity</th>
                        <th>UF</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reserva in Model.Reservas)
                    {
                        <tr>
                            <td>@reserva.FechaReserva.ToString("dd/MM/yyyy")</td>
                            <td>@reserva.HoraInicio.ToString(@"hh\:mm") - @reserva.HoraFin.ToString(@"hh\:mm")</td>
                            <td>@reserva.Amenity.Consorcio.Nombre</td>
                            <td>@reserva.Amenity.Nombre</td>
                            <td>@reserva.UnidadFuncional.NumeroUF</td>
                            <td><span class="status-badge @EstadoClass(reserva.Estado)">@reserva.Estado</span></td>
                            <td>
                                <div class="table-actions">
                                    <a asp-controller="Reservas" asp-action="Details" asp-route-id="@reserva.Id">Ver detalle</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
