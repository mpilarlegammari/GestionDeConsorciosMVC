@model ConsorcioViewModel
@{
    ViewData["Title"] = "Editar Consorcio";
    ViewData["Role"] = "Administrador";
}

<section class="page-intro">
    <div>
        <h2>Editar Consorcio</h2>
        <p>Actualizacion de datos generales y unidades funcionales.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Consorcios" asp-action="Details" asp-route-id="@Model.Id">Cancelar</a>
</section>

@if (!ViewData.ModelState.IsValid)
{
    <section class="form-alert show" role="alert" asp-validation-summary="All"></section>
}

<form class="consorcio-form" data-consorcio-form data-real-submit method="post" asp-controller="Consorcios" asp-action="Edit" asp-route-id="@Model.Id" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <section class="app-card">
        <div class="app-card-title">
            <h3>Datos del consorcio</h3>
            <span class="status-badge">Backend</span>
        </div>
        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="Nombre"></label>
                <input class="form-control" asp-for="Nombre" type="text" data-required />
                <span class="field-validation" asp-validation-for="Nombre" data-error-for="Nombre"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Cuit"></label>
                <input class="form-control" asp-for="Cuit" type="text" data-required />
                <span class="field-validation" asp-validation-for="Cuit" data-error-for="Cuit"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Direccion"></label>
                <input class="form-control" asp-for="Direccion" type="text" data-required />
                <span class="field-validation" asp-validation-for="Direccion" data-error-for="Direccion"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Ciudad"></label>
                <input class="form-control" asp-for="Ciudad" type="text" data-required />
                <span class="field-validation" asp-validation-for="Ciudad" data-error-for="Ciudad"></span>
            </div>
            <div>
                <label class="form-label" asp-for="CodigoPostal"></label>
                <input class="form-control" asp-for="CodigoPostal" type="text" data-required />
                <span class="field-validation" asp-validation-for="CodigoPostal" data-error-for="CodigoPostal"></span>
            </div>
            <div>
                <label class="form-label" asp-for="CantidadPisos"></label>
                <input class="form-control" asp-for="CantidadPisos" type="number" min="1" data-required />
                <span class="field-validation" asp-validation-for="CantidadPisos" data-error-for="CantidadPisos"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Estado"></label>
                <select class="form-select" asp-for="Estado" asp-items="Html.GetEnumSelectList<EstadoConsorcio>()"></select>
                <span class="field-validation" asp-validation-for="Estado" data-error-for="Estado"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Observaciones"></label>
                <textarea class="form-control" asp-for="Observaciones" rows="3"></textarea>
                <span class="field-validation" asp-validation-for="Observaciones" data-error-for="Observaciones"></span>
            </div>
        </div>
    </section>

    <section class="app-card section-card">
        <div class="app-card-title">
            <div>
                <h3>Unidades funcionales</h3>
                <p class="card-description">Actualiza los datos de las UF ya registradas.</p>
            </div>
            <span class="status-badge">@Model.UnidadesFuncionales.Count UF</span>
        </div>
        <div class="form-alert" data-uf-summary></div>
        <div class="table-responsive">
            <table class="table table-clean uf-table">
                <thead>
                    <tr>
                        <th>Numero UF</th>
                        <th>Piso</th>
                        <th>Departamento</th>
                        <th>Nombre propietario</th>
                        <th>Mail propietario</th>
                        <th>DNI propietario</th>
                        <th>Telefono</th>
                    </tr>
                </thead>
                <tbody data-uf-body>
                    @for (var i = 0; i < Model.UnidadesFuncionales.Count; i++)
                    {
                        <tr data-uf-row>
                            <td>
                                <input type="hidden" asp-for="UnidadesFuncionales[i].Id" data-uf-field="Id" />
                                <input class="form-control" asp-for="UnidadesFuncionales[i].NumeroUF" data-uf-field="NumeroUF" type="text" data-uf-numero data-required />
                                <span class="field-validation" asp-validation-for="UnidadesFuncionales[i].NumeroUF" data-uf-error-for="NumeroUF" data-error-for="@($"UnidadesFuncionales[{i}].NumeroUF")"></span>
                            </td>
                            <td><input class="form-control" asp-for="UnidadesFuncionales[i].Piso" data-uf-field="Piso" type="text" /></td>
                            <td><input class="form-control" asp-for="UnidadesFuncionales[i].Departamento" data-uf-field="Departamento" type="text" /></td>
                            <td><input class="form-control" asp-for="UnidadesFuncionales[i].NombrePropietario" data-uf-field="NombrePropietario" type="text" /></td>
                            <td>
                                <input class="form-control" asp-for="UnidadesFuncionales[i].MailPropietario" data-uf-field="MailPropietario" type="email" data-uf-email />
                                <span class="field-validation" asp-validation-for="UnidadesFuncionales[i].MailPropietario" data-uf-error-for="MailPropietario" data-error-for="@($"UnidadesFuncionales[{i}].MailPropietario")"></span>
                            </td>
                            <td>
                                <input class="form-control" asp-for="UnidadesFuncionales[i].DniPropietario" data-uf-field="DniPropietario" type="text" data-uf-dni data-required />
                                <span class="field-validation" asp-validation-for="UnidadesFuncionales[i].DniPropietario" data-uf-error-for="DniPropietario" data-error-for="@($"UnidadesFuncionales[{i}].DniPropietario")"></span>
                            </td>
                            <td><input class="form-control" asp-for="UnidadesFuncionales[i].Telefono" data-uf-field="Telefono" type="tel" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="form-actions">
        <a class="btn btn-outline-secondary" asp-controller="Consorcios" asp-action="Details" asp-route-id="@Model.Id">Cancelar</a>
        <button class="btn btn-primary" type="submit">Guardar cambios</button>
    </section>
</form>
