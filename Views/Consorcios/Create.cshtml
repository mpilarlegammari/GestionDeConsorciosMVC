@model ConsorcioViewModel
@{
    ViewData["Title"] = "Crear Consorcio";
    ViewData["Role"] = "Administrador";
}

<section class="page-intro">
    <div>
        <h2>Crear Consorcio</h2>
        <p>Alta de nuevo edificio y unidades funcionales.</p>
    </div>
    <a class="btn btn-outline-secondary" href="/Consorcios">Cancelar</a>
</section>

@if (!ViewData.ModelState.IsValid)
{
    <section class="form-alert show" role="alert" asp-validation-summary="All"></section>
}

<form class="consorcio-form" data-consorcio-form data-real-submit method="post" asp-controller="Consorcios" asp-action="Create" novalidate>
    @Html.AntiForgeryToken()
    <section class="app-card">
        <div class="app-card-title">
            <h3>Datos del consorcio</h3>
            <span class="status-badge">Backend</span>
        </div>
        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="Nombre"></label>
                <input class="form-control" asp-for="Nombre" type="text" placeholder="Ej: Consorcio Las Heras" data-required />
                <span class="field-validation" asp-validation-for="Nombre" data-error-for="Nombre"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Cuit"></label>
                <input class="form-control" asp-for="Cuit" type="text" placeholder="30-00000000-0" data-required />
                <span class="field-validation" asp-validation-for="Cuit" data-error-for="Cuit"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Direccion"></label>
                <input class="form-control" asp-for="Direccion" type="text" placeholder="Calle y altura" data-required />
                <span class="field-validation" asp-validation-for="Direccion" data-error-for="Direccion"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Ciudad"></label>
                <input class="form-control" asp-for="Ciudad" type="text" placeholder="Ciudad" data-required />
                <span class="field-validation" asp-validation-for="Ciudad" data-error-for="Ciudad"></span>
            </div>
            <div>
                <label class="form-label" asp-for="CodigoPostal"></label>
                <input class="form-control" asp-for="CodigoPostal" type="text" placeholder="Ej: 1425" data-required />
                <span class="field-validation" asp-validation-for="CodigoPostal" data-error-for="CodigoPostal"></span>
            </div>
            <div>
                <label class="form-label" asp-for="CantidadPisos"></label>
                <input class="form-control" asp-for="CantidadPisos" type="number" min="1" placeholder="Ej: 12" data-required />
                <span class="field-validation" asp-validation-for="CantidadPisos" data-error-for="CantidadPisos"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Observaciones"></label>
                <textarea class="form-control" asp-for="Observaciones" rows="3" placeholder="Notas internas o datos relevantes"></textarea>
                <span class="field-validation" asp-validation-for="Observaciones" data-error-for="Observaciones"></span>
            </div>
        </div>
    </section>

    <section class="app-card section-card">
        <div class="app-card-title">
            <div>
                <h3>Unidades funcionales</h3>
                <p class="card-description">Agrega una o mas UF para la carga inicial.</p>
            </div>
            <button class="btn btn-outline-primary" type="button" onclick="agregarUF()">Agregar UF</button>
        </div>
        <div class="form-alert" data-uf-summary></div>
        <div class="table-responsive">
            <table class="table table-clean uf-table">
                <thead>
                    <tr>
                        <th>Numero UF</th>
                        <th>Piso</th>
                        <th>Departamento</th>
                        <th>Nombre propietario</th>
                        <th>Mail propietario</th>
                        <th>DNI propietario</th>
                        <th>Telefono</th>
                        <th>Accion</th>
                    </tr>
                </thead>
                <tbody data-uf-body>
                    @for (var i = 0; i < Model.UnidadesFuncionales.Count; i++)
                    {
                        <tr data-uf-row>
                            <td>
                                <input type="hidden" asp-for="UnidadesFuncionales[i].Id" data-uf-field="Id" />
                                <input class="form-control" asp-for="UnidadesFuncionales[i].NumeroUF" data-uf-field="NumeroUF" type="text" placeholder="001" data-uf-numero data-required />
                                <span class="field-validation" asp-validation-for="UnidadesFuncionales[i].NumeroUF" data-uf-error-for="NumeroUF" data-error-for="@($"UnidadesFuncionales[{i}].NumeroUF")"></span>
                            </td>
                            <td><input class="form-control" asp-for="UnidadesFuncionales[i].Piso" data-uf-field="Piso" type="text" placeholder="1" /></td>
                            <td><input class="form-control" asp-for="UnidadesFuncionales[i].Departamento" data-uf-field="Departamento" type="text" placeholder="A" /></td>
                            <td><input class="form-control" asp-for="UnidadesFuncionales[i].NombrePropietario" data-uf-field="NombrePropietario" type="text" placeholder="Nombre y apellido" /></td>
                            <td>
                                <input class="form-control" asp-for="UnidadesFuncionales[i].MailPropietario" data-uf-field="MailPropietario" type="email" placeholder="propietario@mail.com" data-uf-email />
                                <span class="field-validation" asp-validation-for="UnidadesFuncionales[i].MailPropietario" data-uf-error-for="MailPropietario" data-error-for="@($"UnidadesFuncionales[{i}].MailPropietario")"></span>
                            </td>
                            <td>
                                <input class="form-control" asp-for="UnidadesFuncionales[i].DniPropietario" data-uf-field="DniPropietario" type="text" placeholder="DNI" data-uf-dni data-required />
                                <span class="field-validation" asp-validation-for="UnidadesFuncionales[i].DniPropietario" data-uf-error-for="DniPropietario" data-error-for="@($"UnidadesFuncionales[{i}].DniPropietario")"></span>
                            </td>
                            <td><input class="form-control" asp-for="UnidadesFuncionales[i].Telefono" data-uf-field="Telefono" type="tel" placeholder="Telefono" /></td>
                            <td><button class="btn btn-outline-danger btn-sm" type="button" onclick="eliminarUF(this)">Eliminar</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="app-card section-card">
        <div class="app-card-title">
            <div>
                <h3>Amenities</h3>
                <p class="card-description">Agrega espacios comunes reservables para este consorcio.</p>
            </div>
            <button class="btn btn-outline-primary" type="button" onclick="agregarAmenity()">Agregar amenity</button>
        </div>
        <div class="table-responsive">
            <table class="table table-clean">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Capacidad</th>
                        <th>Descripcion</th>
                        <th>Activo</th>
                        <th>Accion</th>
                    </tr>
                </thead>
                <tbody data-amenity-body>
                    @for (var i = 0; i < Model.Amenities.Count; i++)
                    {
                        <tr data-amenity-row>
                            <td>
                                <input type="hidden" asp-for="Amenities[i].Id" data-amenity-field="Id" />
                                <input class="form-control" asp-for="Amenities[i].Nombre" data-amenity-field="Nombre" type="text" placeholder="SUM, parrilla, terraza" data-amenity-nombre />
                                <span class="field-validation" asp-validation-for="Amenities[i].Nombre" data-amenity-error-for="Nombre" data-error-for="@($"Amenities[{i}].Nombre")"></span>
                            </td>
                            <td>
                                <input class="form-control" asp-for="Amenities[i].Capacidad" data-amenity-field="Capacidad" type="number" min="1" placeholder="10" data-amenity-capacidad />
                                <span class="field-validation" asp-validation-for="Amenities[i].Capacidad" data-amenity-error-for="Capacidad" data-error-for="@($"Amenities[{i}].Capacidad")"></span>
                            </td>
                            <td><input class="form-control" asp-for="Amenities[i].Descripcion" data-amenity-field="Descripcion" type="text" placeholder="Detalle breve del espacio" /></td>
                            <td>
                                <input class="form-check-input" id="@($"Amenities_{i}__Activo")" name="@($"Amenities[{i}].Activo")" data-amenity-field="Activo" type="checkbox" value="true" checked="@Model.Amenities[i].Activo" />
                                <input type="hidden" name="@($"Amenities[{i}].Activo")" value="false" data-amenity-active-hidden />
                            </td>
                            <td><button class="btn btn-outline-danger btn-sm" type="button" onclick="eliminarAmenity(this)">Eliminar</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="form-actions">
        <a class="btn btn-outline-secondary" href="/Consorcios">Cancelar</a>
        <button class="btn btn-primary" type="submit">Crear consorcio</button>
    </section>
</form>
