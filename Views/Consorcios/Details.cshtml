@model ConsorcioDetailsViewModel
@{
    ViewData["Title"] = "Detalle Consorcio";
    ViewData["Role"] = "Administrador";
}

@functions {
    private static string EstadoClass(EstadoConsorcio estado) => estado switch
    {
        EstadoConsorcio.Activo => "success",
        EstadoConsorcio.Pendiente => "warning",
        EstadoConsorcio.Inactivo => "neutral",
        _ => "neutral"
    };

    private static string EstadoUfClass(EstadoUnidadFuncional estado) => estado switch
    {
        EstadoUnidadFuncional.Activa => "success",
        EstadoUnidadFuncional.Morosa => "warning",
        EstadoUnidadFuncional.Inactiva => "neutral",
        _ => "neutral"
    };
}

@if (TempData["Success"] is string successMessage)
{
    <section class="form-alert show success" role="status">@successMessage</section>
}

<section class="page-intro">
    <div>
        <h2>@Model.Nombre</h2>
        <p>@Model.Direccion</p>
        <span class="status-badge @EstadoClass(Model.Estado)">@Model.Estado</span>
    </div>
    <div class="button-group">
        <a class="btn btn-outline-primary" asp-controller="Consorcios" asp-action="Edit" asp-route-id="@Model.Id">Editar consorcio</a>
        <a class="btn btn-outline-primary" href="/Gastos/Create">Registrar gasto</a>
        <a class="btn btn-primary" href="/Expensas/Generar">Generar expensas</a>
    </div>
</section>

<section class="dashboard-grid" aria-label="Resumen consorcio">
    <article class="app-card metric-card">
        <span>Cantidad UF</span>
        <strong>@Model.CantidadUnidades</strong>
        <small>Unidades activas</small>
    </article>
    <article class="app-card metric-card">
        <span>Expensas pendientes</span>
        <strong>@Model.ExpensasPendientes</strong>
        <small>Registradas</small>
    </article>
    <article class="app-card metric-card">
        <span>Gastos del mes</span>
        <strong>@Model.TotalGastos.ToString("C")</strong>
        <small>Total cargado</small>
    </article>
    <article class="app-card metric-card">
        <span>Reclamos abiertos</span>
        <strong>@Model.ReclamosAbiertos</strong>
        <small>En seguimiento</small>
    </article>
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Datos generales del consorcio</h3>
        </div>
        <dl class="detail-list">
            <div>
                <dt>Nombre</dt>
                <dd>@Model.Nombre</dd>
            </div>
            <div>
                <dt>CUIT</dt>
                <dd>@Model.Cuit</dd>
            </div>
            <div>
                <dt>Direccion</dt>
                <dd>@Model.Direccion</dd>
            </div>
            <div>
                <dt>Ciudad</dt>
                <dd>@Model.Ciudad</dd>
            </div>
            <div>
                <dt>Codigo Postal</dt>
                <dd>@Model.CodigoPostal</dd>
            </div>
            <div>
                <dt>Cantidad pisos</dt>
                <dd>@Model.CantidadPisos</dd>
            </div>
            <div>
                <dt>Estado</dt>
                <dd><span class="status-badge @EstadoClass(Model.Estado)">@Model.Estado</span></dd>
            </div>
        </dl>
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Ultimos movimientos</h3>
            <span class="status-badge">Backend</span>
        </div>
        <ul class="activity-list">
            <li><span class="activity-dot success"></span><span>Consorcio creado el @Model.FechaCreacion.ToString("dd/MM/yyyy").</span></li>
            <li><span class="activity-dot"></span><span>@Model.CantidadUnidades unidades funcionales registradas.</span></li>
            <li><span class="activity-dot warning"></span><span>@Model.CantidadGastos gastos cargados.</span></li>
        </ul>
    </aside>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Amenities</h3>
        <span class="status-badge">@Model.Amenities.Count registrados</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Capacidad</th>
                    <th>Descripcion</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Amenities.Count == 0)
                {
                    <tr>
                        <td colspan="4">Este consorcio todavia no tiene amenities cargados.</td>
                    </tr>
                }
                else
                {
                    @foreach (var amenity in Model.Amenities.OrderBy(a => a.Nombre))
                    {
                        <tr>
                            <td>@amenity.Nombre</td>
                            <td>@amenity.Capacidad</td>
                            <td>@(string.IsNullOrWhiteSpace(amenity.Descripcion) ? "-" : amenity.Descripcion)</td>
                            <td>
                                @if (amenity.Activo)
                                {
                                    <span class="status-badge success">Activo</span>
                                }
                                else
                                {
                                    <span class="status-badge neutral">Inactivo</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Unidades funcionales</h3>
        <span class="status-badge">@Model.CantidadUnidades UF</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>UF</th>
                    <th>Piso</th>
                    <th>Departamento</th>
                    <th>Propietario</th>
                    <th>Mail</th>
                    <th>DNI</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.UnidadesFuncionales.Count == 0)
                {
                    <tr>
                        <td colspan="7">Este consorcio todavia no tiene unidades funcionales cargadas.</td>
                    </tr>
                }
                else
                {
                    @foreach (var unidad in Model.UnidadesFuncionales.OrderBy(u => u.NumeroUF))
                    {
                        <tr>
                            <td>@unidad.NumeroUF</td>
                            <td>@unidad.Piso</td>
                            <td>@unidad.Departamento</td>
                            <td>@unidad.NombrePropietario</td>
                            <td>@unidad.MailPropietario</td>
                            <td>@unidad.DniPropietario</td>
                            <td><span class="status-badge @EstadoUfClass(unidad.Estado)">@unidad.Estado</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
