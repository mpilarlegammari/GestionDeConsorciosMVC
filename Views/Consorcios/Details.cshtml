@{
    ViewData["Title"] = "Detalle Consorcio";
    ViewData["Role"] = "Administrador";
}

<section class="page-intro">
    <div>
        <h2>Consorcio Las Heras</h2>
        <p>Av. Las Heras 2450</p>
        <span class="status-badge success">Activo</span>
    </div>
    <div class="button-group">
        <a class="btn btn-outline-primary" href="/Consorcios/Edit/1">Editar consorcio</a>
        <a class="btn btn-outline-primary" href="/Gastos/Create">Registrar gasto</a>
        <a class="btn btn-primary" href="/Expensas/Generar">Generar expensas</a>
    </div>
</section>

<section class="dashboard-grid" aria-label="Resumen consorcio">
    <article class="app-card metric-card">
        <span>Cantidad UF</span>
        <strong>28</strong>
        <small>Unidades activas</small>
    </article>
    <article class="app-card metric-card">
        <span>Expensas pendientes</span>
        <strong>9</strong>
        <small>Mayo 2026</small>
    </article>
    <article class="app-card metric-card">
        <span>Gastos del mes</span>
        <strong>$420.000</strong>
        <small>Mock frontend</small>
    </article>
    <article class="app-card metric-card">
        <span>Reclamos abiertos</span>
        <strong>3</strong>
        <small>En seguimiento</small>
    </article>
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Datos generales del consorcio</h3>
        </div>
        <dl class="detail-list">
            <div>
                <dt>Nombre</dt>
                <dd>Consorcio Las Heras</dd>
            </div>
            <div>
                <dt>Direccion</dt>
                <dd>Av. Las Heras 2450</dd>
            </div>
            <div>
                <dt>Ciudad</dt>
