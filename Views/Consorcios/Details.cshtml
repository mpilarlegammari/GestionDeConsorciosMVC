            </div>
            <div>
                <dt>Codigo Postal</dt>
                <dd>1425</dd>
            </div>
            <div>
                <dt>Cantidad pisos</dt>
                <dd>12</dd>
            </div>
            <div>
                <dt>Estado</dt>
                <dd><span class="status-badge success">Activo</span></dd>
            </div>
        </dl>
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Ultimos movimientos</h3>
            <span class="status-badge">Mock</span>
        </div>
        <ul class="activity-list">
            <li><span class="activity-dot success"></span><span>Gasto registrado.</span></li>
            <li><span class="activity-dot"></span><span>Expensa generada.</span></li>
            <li><span class="activity-dot danger"></span><span>Reclamo creado.</span></li>
            <li><span class="activity-dot warning"></span><span>Comunicado enviado.</span></li>
        </ul>
    </aside>
</section>

