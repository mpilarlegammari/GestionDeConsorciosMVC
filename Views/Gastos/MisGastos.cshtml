<section class="page-intro">
    <div>
        <h2>Gastos del Consorcio</h2>
        <p>Consultá los gastos comunes informados por la administración.</p>
    </div>
    <span class="status-badge">Solo consulta</span>
</section>

<section class="app-card expense-card">
    <div>
        <span class="card-kicker">Consorcio</span>
        <h3>Edificio Las Heras</h3>
        <p>Unidad funcional: UF 3B</p>
    </div>
    <div class="expense-summary">
        <div>
            <span class="card-kicker">Período seleccionado</span>
            <strong>Mayo 2026</strong>
        </div>
        <div>
            <span class="card-kicker">Total gastos del período</span>
            <strong>$1.245.000</strong>
        </div>
        <div>
            <span class="card-kicker">Tu participación estimada</span>
            <strong>$85.000</strong>
        </div>
    </div>
</section>

<section class="app-card filter-card" aria-label="Filtros de mis gastos">
    <form method="get" asp-action="MisGastos">
        <div class="form-grid">
            <div>
                <label class="form-label" for="mes">Mes</label>
                <select class="form-select" id="mes" name="mes">
                    <option value="5">Mayo</option>
                    <option value="4">Abril</option>
                    <option value="3">Marzo</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="anio">Año</label>
                <select class="form-select" id="anio" name="anio">
                    <option>2026</option>
                    <option>2025</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="categoria">Categoría</label>
                <select class="form-select" id="categoria" name="categoria">
                    <option value="">Todas</option>
                    <option>Limpieza</option>
                    <option>Mantenimiento</option>
                    <option>Servicios</option>
                    <option>Seguridad</option>
                    <option>Administración</option>
                    <option>Otros</option>
                </select>
            </div>
            <div class="form-span-2">
                <label class="form-label" for="busqueda">Buscar por concepto o factura</label>
                <input class="form-control" id="busqueda" name="busqueda" type="search" placeholder="Ej: limpieza o FAC-0957" />
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
            </div>
        </div>
    </form>
</section>

