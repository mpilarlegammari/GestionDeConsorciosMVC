@model MisGastosViewModel

@{
    ViewData["Title"] = "Gastos del Consorcio";
    ViewData["Role"] = "Propietario";
}

@functions {
    private static string CategoriaClass(string categoria) => categoria switch
    {
        "Limpieza" => "success",
        "Mantenimiento" => "warning",
        "Seguridad" => "neutral",
        _ => string.Empty
    };

    private static string NombreMes(int mes) => mes switch
    {
        1 => "Enero",
        2 => "Febrero",
        3 => "Marzo",
        4 => "Abril",
        5 => "Mayo",
        6 => "Junio",
        7 => "Julio",
        8 => "Agosto",
        9 => "Septiembre",
        10 => "Octubre",
        11 => "Noviembre",
        12 => "Diciembre",
        _ => $"Mes {mes}"
    };
}

<section class="page-intro">
    <div>
        <h2>Gastos del Consorcio</h2>
        <p>Consulta los gastos comunes informados por la administracion.</p>
    </div>
    <span class="status-badge">Solo consulta</span>
</section>

@if (TempData["Error"] is string errorMessage)
{
    <section class="form-alert show" role="alert">@errorMessage</section>
}

<section class="app-card expense-card">
    <div>
        <span class="card-kicker">Consorcio</span>
        <h3>@Model.ConsorciosResumen</h3>
        <p>Unidades funcionales: @Model.UnidadesResumen</p>
    </div>
    <div class="expense-summary">
        <div>
            <span class="card-kicker">Periodo / filtro</span>
            <strong>@Model.PeriodoResumen</strong>
        </div>
        <div>
            <span class="card-kicker">Total gastos mostrados</span>
            <strong>@Model.TotalGastos.ToString("C")</strong>
        </div>
        <div>
            <span class="card-kicker">Comprobantes</span>
            <strong>@Model.Gastos.Count(gasto => !string.IsNullOrWhiteSpace(gasto.ArchivoFacturaPath))</strong>
        </div>
    </div>
</section>

<section class="app-card filter-card" aria-label="Filtros de mis gastos">
    <form method="get" asp-action="MisGastos">
        <div class="form-grid">
            <div>
                <label class="form-label" for="unidadFuncionalId">Unidad funcional</label>
                <select class="form-select" id="unidadFuncionalId" name="unidadFuncionalId">
                    <option value="">Todas mis UFs</option>
                    @foreach (var unidad in Model.UnidadesFuncionales)
                    {
                        var label = $"{unidad.Consorcio.Nombre} - UF {unidad.NumeroUF}";
                        if (!string.IsNullOrWhiteSpace(unidad.Piso) || !string.IsNullOrWhiteSpace(unidad.Departamento))
                        {
                            label += $" ({unidad.Piso} {unidad.Departamento})";
                        }

                        if (Model.UnidadFuncionalId == unidad.Id)
                        {
                            <option value="@unidad.Id" selected>@label</option>
                        }
                        else
                        {
                            <option value="@unidad.Id">@label</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="mes">Mes</label>
                <select class="form-select" id="mes" name="mes">
                    <option value="">Todos</option>
                    @for (var mes = 1; mes <= 12; mes++)
                    {
                        if (Model.Mes == mes)
                        {
                            <option value="@mes" selected>@NombreMes(mes)</option>
                        }
                        else
                        {
                            <option value="@mes">@NombreMes(mes)</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="anio">Anio</label>
                <select class="form-select" id="anio" name="anio">
                    <option value="">Todos</option>
                    @foreach (var anio in Model.AniosDisponibles)
                    {
                        if (Model.Anio == anio)
                        {
                            <option value="@anio" selected>@anio</option>
                        }
                        else
                        {
                            <option value="@anio">@anio</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="categoria">Categoria</label>
                <select class="form-select" id="categoria" name="categoria">
                    <option value="">Todas</option>
                    @foreach (var categoria in Model.Categorias)
                    {
                        if (Model.Categoria == categoria)
                        {
                            <option value="@categoria" selected>@categoria</option>
                        }
                        else
                        {
                            <option value="@categoria">@categoria</option>
                        }
                    }
                </select>
            </div>
            <div class="form-span-2">
                <label class="form-label" for="busqueda">Buscar por concepto o factura</label>
                <input class="form-control" id="busqueda" name="busqueda" value="@Model.Busqueda" type="search" placeholder="Ej: limpieza o FAC-0957" />
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
                <a class="btn btn-outline-secondary" asp-action="MisGastos">Limpiar</a>
            </div>
        </div>
    </form>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Gastos incluidos en tus consorcios</h3>
        <span class="status-badge">Datos reales</span>
    </div>

    @if (Model.Gastos.Count == 0)
    {
        <p class="empty-state">No hay gastos para los filtros seleccionados.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-clean">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Consorcio</th>
                        <th>Concepto</th>
                        <th>Categoria</th>
                        <th>Nro Factura</th>
                        <th>Monto</th>
                        <th>Comprobante</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gasto in Model.Gastos)
                    {
                        <tr>
                            <td>@gasto.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@gasto.Consorcio.Nombre</td>
                            <td>@gasto.Concepto</td>
                            <td><span class="status-badge @CategoriaClass(gasto.Categoria.ToString())">@gasto.Categoria</span></td>
                            <td>@gasto.NumeroFactura</td>
                            <td>@gasto.Monto.ToString("C")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(gasto.ArchivoFacturaPath))
                                {
                                    <div class="table-actions">
                                        <a href="@gasto.ArchivoFacturaPath" target="_blank" rel="noopener">Ver comprobante</a>
                                        <a href="@gasto.ArchivoFacturaPath" download>Descargar</a>
                                    </div>
                                }
                                else
                                {
                                    <span>Sin archivo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Resumen por categoria</h3>
            <span class="status-badge">@Model.PeriodoResumen</span>
        </div>

        @if (Model.ResumenPorCategoria.Count == 0)
        {
            <p class="empty-state">Sin gastos para resumir.</p>
        }
        else
        {
            <ul class="simple-list">
                @foreach (var item in Model.ResumenPorCategoria)
                {
                    <li>
                        <span>@item.Key</span>
                        <strong>@item.Value.ToString("C")</strong>
                    </li>
                }
            </ul>
        }
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Notas</h3>
        </div>
        <ul class="activity-list">
            <li><span class="activity-dot"></span><span>Los gastos se muestran solo para los consorcios asociados a tus unidades funcionales.</span></li>
            <li><span class="activity-dot success"></span><span>Los comprobantes reales aparecen cuando la administracion cargó factura.</span></li>
            <li><span class="activity-dot warning"></span><span>El monto final de expensas puede incluir ajustes, saldos previos u otros conceptos.</span></li>
        </ul>
    </aside>
</section>
