@model IEnumerable<Gasto>
@{
    ViewData["Title"] = "Gastos";
    ViewData["Role"] = "Administrador";
    var consorcios = ViewBag.Consorcios as IEnumerable<Consorcio> ?? Enumerable.Empty<Consorcio>();
}

@functions {
    private static string CategoriaClass(string? categoria) => categoria?.Trim() switch
    {
        "Limpieza" => "success",
        "Mantenimiento" => "warning",
        "Seguridad" => "neutral",
        _ => string.Empty
    };
}

<section class="page-intro">
    <div>
        <h2>Gastos</h2>
        <p>Registro y consulta de gastos del consorcio.</p>
    </div>
    <a class="btn btn-primary" href="/Gastos/Create">Registrar gasto</a>
</section>

<section class="app-card filter-card" aria-label="Filtros de gastos">
    <div class="form-grid">
        <div>
            <label class="form-label" for="filtroConsorcio">Consorcio</label>
            <select class="form-select" id="filtroConsorcio">
                <option value="">Todos</option>
                @foreach (var consorcio in consorcios)
                {
                    <option value="@consorcio.Id">@consorcio.Nombre</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label" for="filtroMes">Mes</label>
            <select class="form-select" id="filtroMes">
                <option>Mayo</option>
                <option>Abril</option>
                <option>Marzo</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="filtroAnio">Año</label>
            <select class="form-select" id="filtroAnio">
                <option>2026</option>
                <option>2025</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="filtroCategoria">Categoria</label>
            <select class="form-select" id="filtroCategoria">
                <option value="">Todas</option>
                <option>Limpieza</option>
                <option>Mantenimiento</option>
                <option>Servicios</option>
                <option>Seguridad</option>
                <option>Administracion</option>
                <option>Otros</option>
            </select>
        </div>
        <div class="form-span-2">
            <label class="form-label" for="buscarGasto">Buscar por factura o concepto</label>
            <input class="form-control" id="buscarGasto" type="search" placeholder="Ej: FAC-001 o ascensor" />
        </div>
    </div>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Listado de gastos</h3>
        <span class="status-badge">@Model.Count() registrados</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Consorcio</th>
                    <th>N° Factura</th>
                    <th>Concepto</th>
                    <th>Categoria</th>
                    <th>Monto</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7">Todavia no hay gastos cargados.</td>
                    </tr>
                }
                else
                {
                    @foreach (var gasto in Model)
                    {
                        <tr>
                            <td>@gasto.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@gasto.Consorcio.Nombre</td>
                            <td>@gasto.NumeroFactura</td>
                            <td>@gasto.Concepto</td>
                            <td><span class="status-badge @CategoriaClass(gasto.Categoria)">@gasto.Categoria</span></td>
                            <td>@gasto.Monto.ToString("C")</td>
                            <td>
                                <div class="table-actions">
                                    <a asp-controller="Gastos" asp-action="Details" asp-route-id="@gasto.Id">Ver detalle</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
