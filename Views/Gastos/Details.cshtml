@{
    ViewData["Title"] = "Detalle del Gasto";
    ViewData["Role"] = "Administrador";
}

<section class="page-intro">
    <div>
        <h2>Detalle del gasto</h2>
        <p>Factura FAC-0961</p>
        <span class="status-badge success">Registrado</span>
    </div>
    <div class="button-group">
        <a class="btn btn-outline-secondary" href="/Gastos">Volver</a>
        <a class="btn btn-outline-primary" href="/Gastos/Edit/1">Editar</a>
        <a class="btn btn-primary" href="#">Descargar comprobante mock</a>
    </div>
</section>

<section class="dashboard-grid" aria-label="Resumen del gasto">
    <article class="app-card metric-card">
        <span>Monto</span>
        <strong>$180.000</strong>
        <small>Total factura</small>
    </article>
    <article class="app-card metric-card">
        <span>Fecha</span>
        <strong>23/05</strong>
        <small>2026</small>
    </article>
    <article class="app-card metric-card">
        <span>Categoria</span>
        <strong>Mantenimiento</strong>
        <small>Ascensores</small>
    </article>
    <article class="app-card metric-card">
        <span>Consorcio</span>
        <strong>Las Heras</strong>
        <small>Mock</small>
    </article>
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Datos generales</h3>
            <span class="status-badge">Datos mock</span>
        </div>
        <dl class="detail-list">
            <div>
                <dt>Consorcio</dt>
                <dd>Consorcio Las Heras</dd>
            </div>
            <div>
                <dt>Numero de factura</dt>
                <dd>FAC-0961</dd>
            </div>
            <div>
                <dt>Fecha</dt>
                <dd>23/05/2026</dd>
            </div>
            <div>
                <dt>Concepto</dt>
                <dd>Mantenimiento de ascensor</dd>
            </div>
            <div>
                <dt>Categoria</dt>
                <dd><span class="status-badge warning">Mantenimiento</span></dd>
            </div>
            <div>
                <dt>Archivo adjunto</dt>
                <dd>factura-fac-0961.pdf</dd>
            </div>
            <div class="detail-span-2">
                <dt>Descripcion</dt>
                <dd>Servicio mensual de revision, lubricacion y ajuste de ascensores del edificio.</dd>
            </div>
        </dl>
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Historial</h3>
            <span class="status-badge">Mock</span>
        </div>
        <ul class="activity-list">
            <li><span class="activity-dot success"></span><span>Gasto registrado.</span></li>
            <li><span class="activity-dot"></span><span>Comprobante adjuntado.</span></li>
            <li><span class="activity-dot warning"></span><span>Pendiente de incluir en expensas.</span></li>
        </ul>
    </aside>
</section>
