@model Gasto
@{
    ViewData["Title"] = "Detalle del Gasto";
    ViewData["Role"] = "Administrador";
}

@functions {
    private static string CategoriaClass(string? categoria) => categoria?.Trim() switch
    {
        "Limpieza" => "success",
        "Mantenimiento" => "warning",
        "Seguridad" => "neutral",
        _ => string.Empty
    };
}

@if (TempData["Success"] is string successMessage)
{
    <section class="form-alert show success" role="status">@successMessage</section>
}

<section class="page-intro">
    <div>
        <h2>Detalle del gasto</h2>
        <p>Factura @Model.NumeroFactura</p>
        <span class="status-badge success">Registrado</span>
    </div>
    <div class="button-group">
        <a class="btn btn-outline-secondary" href="/Gastos">Volver</a>
        <a class="btn btn-outline-primary" asp-controller="Gastos" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
        <a class="btn btn-outline-danger" asp-controller="Gastos" asp-action="Delete" asp-route-id="@Model.Id">Eliminar</a>
        @if (!string.IsNullOrWhiteSpace(Model.ArchivoFacturaPath))
        {
            <a class="btn btn-primary" href="@Model.ArchivoFacturaPath" target="_blank" rel="noopener">Ver comprobante</a>
        }
    </div>
</section>

<section class="dashboard-grid" aria-label="Resumen del gasto">
    <article class="app-card metric-card">
        <span>Monto</span>
        <strong>@Model.Monto.ToString("C")</strong>
        <small>Total factura</small>
    </article>
    <article class="app-card metric-card">
        <span>Fecha</span>
        <strong>@Model.Fecha.ToString("dd/MM")</strong>
        <small>@Model.Fecha.Year</small>
    </article>
    <article class="app-card metric-card">
        <span>Categoria</span>
        <strong>@Model.Categoria</strong>
        <small>Clasificacion</small>
    </article>
    <article class="app-card metric-card">
        <span>Consorcio</span>
        <strong>@Model.Consorcio.Nombre</strong>
        <small>Asignado</small>
    </article>
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Datos generales</h3>
            <span class="status-badge">Backend</span>
        </div>
        <dl class="detail-list">
            <div>
                <dt>ID interno</dt>
                <dd>@Model.Id</dd>
            </div>
            <div>
                <dt>Consorcio</dt>
                <dd>@Model.Consorcio.Nombre</dd>
            </div>
            <div>
                <dt>Numero de factura</dt>
                <dd>@Model.NumeroFactura</dd>
            </div>
            <div>
                <dt>Fecha</dt>
                <dd>@Model.Fecha.ToString("dd/MM/yyyy")</dd>
            </div>
            <div>
                <dt>Monto</dt>
                <dd>@Model.Monto.ToString("C")</dd>
            </div>
            <div>
                <dt>Concepto</dt>
                <dd>@Model.Concepto</dd>
            </div>
            <div>
                <dt>Categoria</dt>
                <dd><span class="status-badge @CategoriaClass(Model.Categoria.ToString())">@Model.Categoria</span></dd>
            </div>
            <div>
                <dt>Archivo adjunto</dt>
                <dd>
                    @if (!string.IsNullOrWhiteSpace(Model.ArchivoFacturaPath))
                    {
                        <a href="@Model.ArchivoFacturaPath" target="_blank" rel="noopener">Ver comprobante</a>
                    }
                    else
                    {
                        <span>Sin comprobante adjunto</span>
                    }
                </dd>
            </div>
            <div class="detail-span-2">
                <dt>Descripcion</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripcion adicional." : Model.Descripcion)</dd>
            </div>
            <div>
                <dt>Fecha de carga</dt>
                <dd>@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</dd>
            </div>
        </dl>
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Historial</h3>
            <span class="status-badge">Backend</span>
        </div>
        <ul class="activity-list">
            <li><span class="activity-dot success"></span><span>Gasto registrado el @Model.FechaCreacion.ToString("dd/MM/yyyy").</span></li>
            @if (!string.IsNullOrWhiteSpace(Model.ArchivoFacturaPath))
            {
                <li><span class="activity-dot"></span><span>Comprobante adjuntado.</span></li>
            }
            <li><span class="activity-dot warning"></span><span>Pendiente de incluir en expensas.</span></li>
        </ul>
    </aside>
</section>
