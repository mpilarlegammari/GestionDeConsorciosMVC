@model GastoVM
@{
    ViewData["Title"] = "Editar Gasto";
    ViewData["Role"] = "Administrador";
    var consorcios = ViewBag.Consorcios as IEnumerable<Consorcio> ?? Enumerable.Empty<Consorcio>();
    var categorias = ViewBag.Categorias as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<section class="page-intro">
    <div>
        <h2>Editar Gasto</h2>
        <p>Actualizacion de datos del gasto y comprobante.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Gastos" asp-action="Details" asp-route-id="@Model.Id">Cancelar</a>
</section>

@if (TempData["Error"] is string errorMessage)
{
    <section class="form-alert show" role="alert">@errorMessage</section>
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="consorcio-form" data-gasto-form data-real-submit novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ArchivoFacturaPath" />

    <section class="app-card">
        <div class="app-card-title">
            <div>
                <h3>Datos del gasto</h3>
                <p class="card-description">Los cambios se aplican al gasto registrado.</p>
            </div>
            <span class="status-badge">Backend</span>
        </div>

        <div class="form-alert" data-gasto-summary></div>

        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="ConsorcioId">Consorcio</label>
                <select class="form-select" asp-for="ConsorcioId" data-gasto-required>
                    <option value="">Seleccionar consorcio</option>
                    @foreach (var consorcio in consorcios)
                    {
                        if (Model.ConsorcioId == consorcio.Id)
                        {
                            <option value="@consorcio.Id" selected>@consorcio.Nombre</option>
                        }
                        else
                        {
                            <option value="@consorcio.Id">@consorcio.Nombre</option>
                        }
                    }
                </select>
                <span class="field-validation" asp-validation-for="ConsorcioId" data-error-for="ConsorcioId"></span>
            </div>
            <div>
                <label class="form-label" asp-for="NumeroFactura">Numero de factura</label>
                <input class="form-control" asp-for="NumeroFactura" type="text" data-gasto-required />
                <span class="field-validation" asp-validation-for="NumeroFactura" data-error-for="NumeroFactura"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Fecha"></label>
                <input class="form-control" asp-for="Fecha" type="date" data-gasto-required />
                <span class="field-validation" asp-validation-for="Fecha" data-error-for="Fecha"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Monto"></label>
                <input class="form-control" asp-for="Monto" type="number" min="1" step="0.01" data-gasto-required data-gasto-monto />
                <span class="field-validation" asp-validation-for="Monto" data-error-for="Monto"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Categoria"></label>
                <select class="form-select" asp-for="Categoria" data-gasto-required>
                    <option value="">Seleccionar categoria</option>
                    @foreach (var categoria in categorias)
                    {
                        if (string.Equals(Model.Categoria, categoria, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@categoria" selected>@categoria</option>
                        }
                        else
                        {
                            <option value="@categoria">@categoria</option>
                        }
                    }
                </select>
                <span class="field-validation" asp-validation-for="Categoria" data-error-for="Categoria"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Concepto"></label>
                <input class="form-control" asp-for="Concepto" type="text" data-gasto-required />
                <span class="field-validation" asp-validation-for="Concepto" data-error-for="Concepto"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Descripcion">Descripcion opcional</label>
                <textarea class="form-control" asp-for="Descripcion" rows="4"></textarea>
                <span class="field-validation" asp-validation-for="Descripcion" data-error-for="Descripcion"></span>
            </div>
        </div>
    </section>

    <section class="app-card">
        <div class="app-card-title">
            <div>
                <h3>Comprobante</h3>
                <p class="card-description">Adjunta uno nuevo solo si queres reemplazar el comprobante actual.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ArchivoFacturaPath))
        {
            <div class="form-alert show success" role="status">
                Comprobante actual: <a href="@Model.ArchivoFacturaPath" target="_blank" rel="noopener">ver archivo</a>
            </div>
        }

        <label class="file-drop" for="ArchivoFactura">
            <span class="quick-action-icon">F</span>
            <span>
                <strong>Reemplazar factura/comprobante</strong>
                <small>Formatos permitidos: pdf, jpg, jpeg, png.</small>
            </span>
        </label>
        <input class="visually-hidden" id="ArchivoFactura" name="ArchivoFactura" type="file" accept=".pdf,.jpg,.jpeg,.png" data-gasto-file onchange="mostrarArchivoSeleccionado(this)" />
        <span class="field-validation" data-valmsg-for="ArchivoFactura" data-error-for="ArchivoFactura"></span>
        <div class="file-preview" data-file-preview></div>
    </section>

    <section class="form-actions">
        <a class="btn btn-outline-secondary" asp-controller="Gastos" asp-action="Details" asp-route-id="@Model.Id">Cancelar</a>
        <button class="btn btn-primary" type="submit">Guardar cambios</button>
    </section>
</form>
