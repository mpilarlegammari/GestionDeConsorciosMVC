@{
    ViewData["Title"] = "Panel Propietario";
    ViewData["Role"] = "Propietario";
}

<section class="page-intro">
    <div>
        <h2>Panel Propietario</h2>
        <p>Consulta tus expensas, pagos, comunicados y reservas.</p>
    </div>
    <span class="status-badge">Datos mock</span>
</section>

<section class="app-card expense-card">
    <div>
        <span class="card-kicker">Expensa actual</span>
        <h3>Periodo: Mayo 2026</h3>
        <p>Vencimiento: 10/06/2026</p>
    </div>
    <div class="expense-summary">
        <strong>$85.000</strong>
        <span class="status-badge warning">Pendiente</span>
        <a class="btn btn-primary" href="/Pagos/InformarPago">Informar pago</a>
    </div>
</section>

<section class="quick-actions" aria-label="Accesos rapidos propietario">
    <a class="quick-action" href="/Expensas/MisExpensas">
        <span class="quick-action-icon">E</span>
        <span>
            <strong>Ver expensas</strong>
            <span>Consultar vencimientos</span>
        </span>
    </a>
    <a class="quick-action" href="/Pagos/InformarPago">
        <span class="quick-action-icon">P</span>
        <span>
            <strong>Informar pago</strong>
            <span>Cargar comprobante</span>
        </span>
    </a>
    <a class="quick-action" href="/Reclamos/Create">
        <span class="quick-action-icon">R</span>
        <span>
            <strong>Nuevo reclamo</strong>
            <span>Contactar administracion</span>
        </span>
    </a>
    <a class="quick-action" href="/Reservas/Create">
        <span class="quick-action-icon">A</span>
        <span>
            <strong>Reservar amenity</strong>
            <span>Elegir espacio y horario</span>
        </span>
    </a>
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Ultimos comunicados</h3>
            <span class="status-badge">3 nuevos</span>
        </div>
        <ul class="activity-list">
            <li>
                <span class="activity-dot warning"></span>
                <span>Corte de agua programado.</span>
            </li>
            <li>
                <span class="activity-dot"></span>
                <span>Limpieza de tanques.</span>
            </li>
            <li>
                <span class="activity-dot success"></span>
                <span>Asamblea ordinaria.</span>
            </li>
        </ul>
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Unidad funcional</h3>
        </div>
        <ul class="simple-list">
            <li>
                <span>Consorcio</span>
                <strong>Consorcio Las Heras</strong>
            </li>
            <li>
                <span>Unidad</span>
                <strong>4B</strong>
            </li>
            <li>
                <span>Estado</span>
                <strong>Pendiente</strong>
            </li>
        </ul>
    </aside>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Mis ultimos pagos</h3>
        <span class="status-badge">Mock</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Periodo</th>
                    <th>Fecha de pago</th>
                    <th>Monto</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Abril 2026</td>
                    <td>12/05/2026</td>
                    <td>$79.500</td>
                    <td><span class="status-badge success">Validado</span></td>
                </tr>
                <tr>
                    <td>Marzo 2026</td>
                    <td>09/04/2026</td>
                    <td>$76.200</td>
                    <td><span class="status-badge success">Validado</span></td>
                </tr>
                <tr>
                    <td>Mayo 2026</td>
                    <td>-</td>
                    <td>$85.000</td>
                    <td><span class="status-badge warning">Pendiente</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</section>
