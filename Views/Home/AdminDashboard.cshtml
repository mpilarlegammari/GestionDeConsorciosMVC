@model GestionDeConsorciosMVC.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Panel Administrador";
    ViewData["Role"] = "Administrador";

    string Money(decimal value) => value.ToString("C0", new System.Globalization.CultureInfo("es-AR"));
    string ConsorcioBadge(EstadoConsorcio estado) => estado switch
    {
        EstadoConsorcio.Activo => "success",
        EstadoConsorcio.Inactivo => "danger",
        _ => "warning"
    };
}

<section class="page-intro">
    <div>
        <h2>Panel Administrador</h2>
        <p>Resumen general con informacion real de consorcios, expensas, pagos y reclamos.</p>
    </div>
    <span class="status-badge success">Datos reales</span>
</section>

<section class="quick-actions" aria-label="Accesos rapidos administrador">
    <a class="quick-action" href="/Consorcios/Create">
        <span class="quick-action-icon">C</span>
        <span>
            <strong>Crear consorcio</strong>
            <span>@Model.TotalConsorcios consorcios cargados</span>
        </span>
    </a>
    <a class="quick-action" href="/Gastos/Create">
        <span class="quick-action-icon">G</span>
        <span>
            <strong>Registrar gasto</strong>
            <span>@Model.TotalUnidadesFuncionales unidades administradas</span>
        </span>
    </a>
    <a class="quick-action" href="/Expensas/Generar">
        <span class="quick-action-icon">E</span>
        <span>
            <strong>Generar expensas</strong>
            <span>@Model.ExpensasPendientes expensas pendientes</span>
        </span>
    </a>
    <a class="quick-action" href="/Comunicados/Create">
        <span class="quick-action-icon">M</span>
        <span>
            <strong>Nuevo comunicado</strong>
            <span>@Model.ComunicadosImportantes importantes</span>
        </span>
    </a>
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Actividad reciente</h3>
            <span class="status-badge">@Model.ActividadReciente.Count eventos</span>
        </div>
        @if (Model.ActividadReciente.Any())
        {
            <ul class="activity-list">
                @foreach (var item in Model.ActividadReciente)
                {
                    <li>
                        <span class="activity-dot @item.Tone"></span>
                        <span>@item.Tipo: @item.Detalle (@item.Estado)</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <partial name="_EmptyState" model="@("Todavia no hay actividad registrada.")" />
        }
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Estado operativo</h3>
        </div>
        <ul class="simple-list">
            <li>
                <span>Expensas pendientes</span>
                <strong>@Money(Model.MontoExpensasPendientes)</strong>
            </li>
            <li>
                <span>Pagos pendientes previos</span>
                <strong>@Model.PagosPendientesRevision</strong>
            </li>
            <li>
                <span>Reclamos abiertos</span>
                <strong>@Model.ReclamosAbiertos</strong>
            </li>
            <li>
                <span>Reservas pendientes</span>
                <strong>@Model.ReservasPendientes</strong>
            </li>
        </ul>
    </aside>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Consorcios recientes</h3>
        <span class="status-badge">@Model.ConsorciosRecientes.Count visibles</span>
    </div>
    @if (Model.ConsorciosRecientes.Any())
    {
        <div class="table-responsive">
            <table class="table table-clean">
                <thead>
                    <tr>
                        <th>Consorcio</th>
                        <th>Direccion</th>
                        <th>Cantidad UF</th>
                        <th>Estado</th>
                        <th>Accion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var consorcio in Model.ConsorciosRecientes)
                    {
                        <tr>
                            <td>@consorcio.Nombre</td>
                            <td>@consorcio.Direccion</td>
                            <td>@consorcio.CantidadUnidades</td>
                            <td><span class="status-badge @ConsorcioBadge(consorcio.Estado)">@consorcio.Estado</span></td>
                            <td>
                                <a asp-controller="Consorcios" asp-action="Details" asp-route-id="@consorcio.Id" class="table-action">Ver</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <partial name="_EmptyState" model="@("Todavia no hay consorcios cargados.")" />
    }
</section>
