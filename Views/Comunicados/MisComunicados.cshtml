@model MisComunicadosViewModel

@{
    ViewData["Title"] = "Mis Comunicados";
    ViewData["Role"] = "Propietario";
    var returnUrl = Context.Request.Path + Context.Request.QueryString.ToString();
}

<section class="page-intro">
    <div>
        <h2>Mis Comunicados</h2>
        <p>Avisos y novedades enviados por la administracion.</p>
    </div>
    <span class="status-badge">Solo lectura</span>
</section>

<section class="app-card filter-card" aria-label="Filtros de mis comunicados">
    <form method="get" asp-action="MisComunicados">
        <div class="form-grid">
            <div>
                <label class="form-label" for="importante">Importancia</label>
                <select class="form-select" id="importante" name="importante">
                    <option value="">Todos</option>
                    @if (Model.Importante == true)
                    {
                        <option value="true" selected>Importantes</option>
                        <option value="false">Normales</option>
                    }
                    else if (Model.Importante == false)
                    {
                        <option value="true">Importantes</option>
                        <option value="false" selected>Normales</option>
                    }
                    else
                    {
                        <option value="true">Importantes</option>
                        <option value="false">Normales</option>
                    }
                </select>
            </div>
            <div class="form-span-2">
                <label class="form-label" for="busqueda">Buscar por titulo o mensaje</label>
                <input class="form-control" id="busqueda" name="busqueda" value="@Model.Busqueda" type="search" placeholder="Ej: asamblea" />
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
                <a class="btn btn-outline-secondary" asp-action="MisComunicados">Limpiar</a>
            </div>
        </div>
    </form>
</section>

<section class="summary-grid" aria-label="Resumen de mis comunicados">
    <article class="app-card metric-card">
        <span>Total</span>
        <strong>@Model.CantidadComunicados</strong>
    </article>
    <article class="app-card metric-card">
        <span>Importantes</span>
        <strong>@Model.CantidadImportantes</strong>
    </article>
    <article class="app-card metric-card">
        <span>Con adjunto</span>
        <strong>@Model.CantidadConAdjunto</strong>
    </article>
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Comunicados recibidos</h3>
            <span class="status-badge">@Model.ConsorciosResumen</span>
        </div>

        @if (Model.Comunicados.Count == 0)
        {
            <p class="empty-state">No hay comunicados disponibles para tu consorcio con los filtros seleccionados.</p>
        }
        else
        {
            <ul class="activity-list">
                @foreach (var comunicado in Model.Comunicados)
                {
                    var resumen = comunicado.Mensaje.Length > 160
                        ? comunicado.Mensaje.Substring(0, 160) + "..."
                        : comunicado.Mensaje;

                    <li>
                        <span class="activity-dot @(comunicado.Importante ? "warning" : string.Empty)"></span>
                        <span>
                            <strong>@comunicado.FechaPublicacion.ToString("dd/MM/yyyy") - @comunicado.Titulo</strong><br />
                            @resumen
                            @if (comunicado.Importante)
                            {
                                <span class="status-badge warning">Importante</span>
                            }
                            else
                            {
                                <span class="status-badge neutral">Normal</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(comunicado.ArchivoAdjuntoPath))
                            {
                                <span class="status-badge">Adjunto</span>
                            }
                            <span class="table-actions">
                                <a asp-controller="Comunicados"
                                   asp-action="Details"
                                   asp-route-id="@comunicado.Id"
                                   asp-route-rol="propietario"
                                   asp-route-returnUrl="@returnUrl">Ver detalle</a>
                            </span>
                        </span>
                    </li>
                }
            </ul>
        }
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Notas</h3>
        </div>
        <ul class="simple-list">
            <li>
                <span>Perfil</span>
                <strong>Propietario</strong>
            </li>
            <li>
                <span>Consorcio</span>
                <strong>@Model.ConsorciosResumen</strong>
            </li>
            <li>
                <span>Acciones</span>
                <strong>Solo lectura</strong>
            </li>
        </ul>
    </aside>
</section>
