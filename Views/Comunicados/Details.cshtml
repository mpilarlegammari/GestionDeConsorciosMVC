@model ComunicadoDetailsViewModel

@{
    ViewData["Title"] = "Detalle Comunicado";
    ViewData["Role"] = Model.DetailRole;
    var esPropietario = Model.DetailRole.Equals("Propietario", StringComparison.OrdinalIgnoreCase);
    var archivoNombre = string.IsNullOrWhiteSpace(Model.ArchivoAdjuntoPath)
        ? "Sin adjunto"
        : System.IO.Path.GetFileName(Model.ArchivoAdjuntoPath);
}

<section class="page-intro">
    <div>
        <h2>@Model.Titulo</h2>
        <p>Detalle del comunicado publicado el @Model.FechaPublicacion.ToString("dd/MM/yyyy").</p>
    </div>
    @if (Model.Importante)
    {
        <span class="status-badge warning">Importante</span>
    }
    else
    {
        <span class="status-badge neutral">Normal</span>
    }
</section>

<section class="content-grid">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Mensaje completo</h3>
            <span class="status-badge">@Model.ConsorcioNombre</span>
        </div>
        <dl class="detail-list">
            <div>
                <dt>Fecha</dt>
                <dd>@Model.FechaPublicacion.ToString("dd/MM/yyyy HH:mm")</dd>
            </div>
            <div>
                <dt>Consorcio</dt>
                <dd>@Model.ConsorcioNombre</dd>
            </div>
            <div>
                <dt>Estado importante</dt>
                <dd>
                    @if (Model.Importante)
                    {
                        <span class="status-badge warning">Importante</span>
                    }
                    else
                    {
                        <span class="status-badge neutral">Normal</span>
                    }
                </dd>
            </div>
            <div>
                <dt>Archivo adjunto</dt>
                <dd>@archivoNombre</dd>
            </div>
            <div class="detail-span-2">
                <dt>Mensaje</dt>
                <dd>@Model.Mensaje</dd>
            </div>
        </dl>
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Adjunto</h3>
            <span class="status-badge">Archivo</span>
        </div>
        <ul class="simple-list">
            <li>
                <span>Archivo</span>
                <strong>@archivoNombre</strong>
            </li>
            <li>
                <span>Disponibilidad</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.ArchivoAdjuntoPath) ? "Sin adjunto" : "Disponible")</strong>
            </li>
            <li>
                <span>Vista</span>
                @if (!string.IsNullOrWhiteSpace(Model.ArchivoAdjuntoPath))
                {
                    <a href="@Model.ArchivoAdjuntoPath" target="_blank" rel="noopener">Abrir adjunto</a>
                }
                else
                {
                    <strong>No aplica</strong>
                }
            </li>
        </ul>
    </aside>
</section>

<section class="app-card section-card">
    <div class="button-group">
        <a class="btn btn-outline-secondary" href="@Model.ReturnUrl">Volver</a>
        @if (!string.IsNullOrWhiteSpace(Model.ArchivoAdjuntoPath))
        {
            <a class="btn btn-primary" href="@Model.ArchivoAdjuntoPath" target="_blank" rel="noopener">Descargar adjunto</a>
        }
        @if (!esPropietario)
        {
            <a class="btn btn-outline-primary" asp-controller="Comunicados" asp-action="Create">Nuevo comunicado</a>
        }
    </div>
</section>
