@model ComunicadoCreateViewModel

@{
    ViewData["Title"] = "Nuevo comunicado";
    ViewData["Role"] = "Administrador";
}

<section class="page-intro">
    <div>
        <h2>Nuevo comunicado</h2>
        <p>Publica un aviso para los propietarios de un consorcio.</p>
    </div>
    <span class="status-badge">Persistencia real</span>
</section>

@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form asp-action="Create" method="post" enctype="multipart/form-data" data-comunicado-form data-real-submit>
    <section class="app-card section-card">
        <div class="app-card-title">
            <h3>Datos del comunicado</h3>
            <span class="status-badge">Backend</span>
        </div>

        <div asp-validation-summary="ModelOnly" class="field-validation"></div>

        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="ConsorcioId">Consorcio</label>
                <select class="form-select" asp-for="ConsorcioId" data-comunicado-required>
                    <option value="">Seleccionar consorcio</option>
                    @foreach (var consorcio in Model.Consorcios)
                    {
                        <option value="@consorcio.Id">@consorcio.Nombre</option>
                    }
                </select>
                <span asp-validation-for="ConsorcioId" class="field-validation" data-error-for="ConsorcioId"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Titulo">Titulo</label>
                <input class="form-control" asp-for="Titulo" type="text" placeholder="Ej: Corte de agua programado" data-comunicado-required />
                <span asp-validation-for="Titulo" class="field-validation" data-error-for="Titulo"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Mensaje">Mensaje</label>
                <textarea class="form-control" asp-for="Mensaje" rows="6" placeholder="Escribi el contenido del comunicado." data-comunicado-required></textarea>
                <span asp-validation-for="Mensaje" class="field-validation" data-error-for="Mensaje"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Importante">Importancia</label>
                <div class="form-check">
                    <input class="form-check-input" asp-for="Importante" type="checkbox" />
                    <label class="form-check-label" asp-for="Importante">Marcar como importante</label>
                </div>
            </div>
            <div class="form-span-2">
                <label class="form-label" for="ArchivoAdjunto">Adjuntar archivo opcional</label>
                <input class="form-control" id="ArchivoAdjunto" name="ArchivoAdjunto" type="file" accept=".pdf,.jpg,.jpeg,.png" data-comunicado-file onchange="mostrarAdjuntoComunicadoSeleccionado(this)" />
                <span class="field-validation" data-error-for="ArchivoAdjunto">@Html.ValidationMessage("ArchivoAdjunto")</span>
                <div class="file-preview" data-comunicado-file-preview></div>
            </div>
        </div>

        <p class="form-note">El comunicado sera visible para los propietarios del consorcio seleccionado. Formatos permitidos: pdf, jpg, jpeg o png, hasta 5 MB.</p>
        <div class="form-summary" data-comunicado-summary></div>

        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-controller="Comunicados" asp-action="Index">Cancelar</a>
            <button class="btn btn-primary" type="submit">Enviar comunicado</button>
        </div>
    </section>
</form>
