@model ExpensaDetailsViewModel
@{
    ViewData["Title"] = "Detalle de Expensa";
    ViewData["Role"] = Model.DetailRole;
}

@functions {
    private static string EstadoClass(EstadoExpensa estado) => estado switch
    {
        EstadoExpensa.Pagada => "success",
        EstadoExpensa.Pendiente => "warning",
        EstadoExpensa.Vencida => "danger",
        _ => "neutral"
    };

    private static string CategoriaClass(string? categoria) => categoria?.Trim() switch
    {
        "Limpieza" => "success",
        "Mantenimiento" => "warning",
        "Seguridad" => "neutral",
        _ => string.Empty
    };
}

<section class="page-intro">
    <div>
        <h2>Detalle de Expensa</h2>
        <p>Periodo @Model.Periodo</p>
    </div>
    <span class="status-badge @EstadoClass(Model.Estado)">@Model.Estado</span>
</section>

<section class="dashboard-grid">
    <article class="app-card metric-card">
        <span>Total</span>
        <strong>@Model.MontoTotal.ToString("C")</strong>
        <small>Liquidacion mensual</small>
    </article>
    <article class="app-card metric-card">
        <span>Vencimiento</span>
        <strong>@Model.FechaVencimiento.ToString("dd/MM")</strong>
        <small>@Model.FechaVencimiento.Year</small>
    </article>
    <article class="app-card metric-card">
        <span>Estado</span>
        <strong><span class="status-badge @EstadoClass(Model.Estado)">@Model.Estado</span></strong>
        <small>@Model.Pagos.Count pagos asociados</small>
    </article>
    <article class="app-card metric-card">
        <span>Fecha emision</span>
        <strong>@Model.FechaEmision.ToString("dd/MM")</strong>
        <small>@Model.FechaEmision.Year</small>
    </article>
</section>

<section class="content-grid section-card">
    <article class="app-card">
        <div class="app-card-title">
            <h3>Datos generales</h3>
        </div>
        <dl class="detail-list">
            <div>
                <dt>Consorcio</dt>
                <dd>@Model.ConsorcioNombre</dd>
            </div>
            <div>
                <dt>Unidad funcional</dt>
                <dd>@Model.UnidadFuncionalNumero</dd>
            </div>
            <div>
                <dt>Propietario</dt>
                <dd>@Model.PropietarioNombre</dd>
            </div>
            <div>
                <dt>Email propietario</dt>
                <dd>@Model.PropietarioMail</dd>
            </div>
            <div>
                <dt>Periodo</dt>
                <dd>@Model.Periodo</dd>
            </div>
            <div>
                <dt>Fecha emision</dt>
                <dd>@Model.FechaEmision.ToString("dd/MM/yyyy")</dd>
            </div>
            <div>
                <dt>Fecha vencimiento</dt>
                <dd>@Model.FechaVencimiento.ToString("dd/MM/yyyy")</dd>
            </div>
            <div>
                <dt>Estado</dt>
                <dd><span class="status-badge @EstadoClass(Model.Estado)">@Model.Estado</span></dd>
            </div>
            <div class="detail-span-2">
                <dt>Metodo de distribucion</dt>
                <dd>Partes iguales por unidad funcional.</dd>
            </div>
        </dl>
    </article>

    <aside class="app-card">
        <div class="app-card-title">
            <h3>Pagos</h3>
        </div>
        <ul class="simple-list">
            <li>
                <span>Total pagado</span>
                <strong>@Model.TotalPagadoAprobado.ToString("C")</strong>
            </li>
            <li>
                <span>Pagos pendientes</span>
                <strong>@Model.PagosPendientes</strong>
            </li>
            <li>
                <span>Observaciones</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.Observaciones) ? "Sin observaciones" : Model.Observaciones)</strong>
            </li>
        </ul>
    </aside>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Detalle de gastos</h3>
        <span class="status-badge">Incluidos en la liquidacion</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Concepto</th>
                    <th>Categoria</th>
                    <th>Monto</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Gastos.Any())
                {
                    <tr>
                        <td colspan="4">No se encontraron gastos para este periodo.</td>
                    </tr>
                }
                else
                {
                    @foreach (var gasto in Model.Gastos)
                    {
                        <tr>
                            <td>@gasto.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@gasto.Concepto</td>
                            <td><span class="status-badge @CategoriaClass(gasto.Categoria)">@gasto.Categoria</span></td>
                            <td>@gasto.Monto.ToString("C")</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3">Total general</th>
                    <th>@Model.TotalGeneralGastos.ToString("C")</th>
                </tr>
            </tfoot>
        </table>
    </div>
</section>

<section class="app-card section-card">
    <div class="button-group">
        <a class="btn btn-outline-secondary" href="@Model.ReturnUrl">Volver</a>
        <a class="btn btn-primary" href="/Pagos/InformarPago">Informar pago</a>
    </div>
</section>
