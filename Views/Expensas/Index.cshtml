<section class="page-intro">
    <div>
        <h2>Expensas</h2>
        <p>Gestión de liquidaciones por consorcio y período.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Expensas" asp-action="Generar">Generar Expensas</a>
</section>

<section class="dashboard-grid">
    <article class="app-card metric-card">
        <span>Total liquidado del mes</span>
        <strong>$8.450.000</strong>
        <small>Mayo 2026</small>
    </article>
    <article class="app-card metric-card">
        <span>Expensas generadas</span>
        <strong>86</strong>
        <small>Liquidaciones emitidas</small>
    </article>
    <article class="app-card metric-card">
        <span>Pendientes de pago</span>
        <strong>23</strong>
        <small>Requieren seguimiento</small>
    </article>
    <article class="app-card metric-card">
        <span>Pagadas</span>
        <strong>63</strong>
        <small>Con pago aprobado</small>
    </article>
</section>

<section class="app-card filter-card" aria-label="Filtros de expensas">
    <form method="get" asp-action="Index">
        <div class="form-grid">
            <div>
                <label class="form-label" for="consorcio">Consorcio</label>
                <select class="form-select" id="consorcio" name="consorcio">
                    <option value="">Todos</option>
                    <option>Edificio Las Heras</option>
                    <option>Consorcio San Martín</option>
                    <option>Torre Belgrano</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="mes">Mes</label>
                <select class="form-select" id="mes" name="mes">
                    <option value="5">Mayo</option>
                    <option value="4">Abril</option>
                    <option value="3">Marzo</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="anio">Año</label>
                <select class="form-select" id="anio" name="anio">
                    <option>2026</option>
                    <option>2025</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="estado">Estado</label>
                <select class="form-select" id="estado" name="estado">
                    <option value="">Todos</option>
                    <option>Pendiente</option>
                    <option>Pagada</option>
                    <option>Vencida</option>
                </select>
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
            </div>
        </div>
    </form>
</section>

