@model IEnumerable<Expensa>
@{
    ViewData["Title"] = "Expensas";
    ViewData["Role"] = "Administrador";
    var consorcios = ViewBag.Consorcios as IEnumerable<Consorcio> ?? Enumerable.Empty<Consorcio>();
}

@functions {
    private static string EstadoClass(EstadoExpensa estado) => estado switch
    {
        EstadoExpensa.Pagada => "success",
        EstadoExpensa.Pendiente => "warning",
        EstadoExpensa.Vencida => "danger",
        _ => "neutral"
    };
}

@if (TempData["Success"] is string successMessage)
{
    <section class="form-alert show success" role="status">@successMessage</section>
}

<section class="page-intro">
    <div>
        <h2>Expensas</h2>
        <p>Gestion de liquidaciones por consorcio y periodo.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Expensas" asp-action="Generar">Generar expensas</a>
</section>

<section class="app-card filter-card" aria-label="Filtros de expensas">
    <form method="get" asp-action="Index">
        <div class="form-grid">
            <div>
                <label class="form-label" for="consorcio">Consorcio</label>
                <select class="form-select" id="consorcio" name="consorcio">
                    <option value="">Todos</option>
                    @foreach (var consorcio in consorcios)
                    {
                        <option value="@consorcio.Id">@consorcio.Nombre</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="mes">Mes</label>
                <select class="form-select" id="mes" name="mes">
                    <option value="5">Mayo</option>
                    <option value="4">Abril</option>
                    <option value="3">Marzo</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="anio">Anio</label>
                <select class="form-select" id="anio" name="anio">
                    <option>2026</option>
                    <option>2025</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="estado">Estado</label>
                <select class="form-select" id="estado" name="estado">
                    <option value="">Todos</option>
                    <option>Pendiente</option>
                    <option>Pagada</option>
                    <option>Vencida</option>
                </select>
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
            </div>
        </div>
    </form>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Liquidaciones generadas</h3>
        <span class="status-badge">@Model.Count() registradas</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Periodo</th>
                    <th>Consorcio</th>
                    <th>UF</th>
                    <th>Propietario</th>
                    <th>Monto</th>
                    <th>Vencimiento</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8">Todavia no hay expensas generadas.</td>
                    </tr>
                }
                else
                {
                    @foreach (var expensa in Model)
                    {
                        <tr>
                            <td>@expensa.Periodo</td>
                            <td>@expensa.UnidadFuncional.Consorcio.Nombre</td>
                            <td>@expensa.UnidadFuncional.NumeroUF</td>
                            <td>@expensa.UnidadFuncional.NombrePropietario</td>
                            <td>@expensa.MontoTotal.ToString("C")</td>
                            <td>@expensa.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                            <td><span class="status-badge @EstadoClass(expensa.Estado)">@expensa.Estado</span></td>
                            <td>
                                <div class="table-actions">
                                    <a asp-controller="Expensas" asp-action="Details" asp-route-id="@expensa.Id" asp-route-returnUrl="@Url.Action("Index", "Expensas")">Ver detalle</a>
                                    <a href="/Pagos/MisPagos">Ver pagos</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
