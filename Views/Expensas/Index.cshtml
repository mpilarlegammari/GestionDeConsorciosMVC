@model ExpensasIndexViewModel
@{
    ViewData["Title"] = "Expensas";
    ViewData["Role"] = "Administrador";
}

@functions {
    private static string EstadoClass(EstadoExpensa estado) => estado switch
    {
        EstadoExpensa.Pagada => "success",
        EstadoExpensa.Pendiente => "warning",
        EstadoExpensa.Vencida => "danger",
        _ => "neutral"
    };
}

@if (TempData["Success"] is string successMessage)
{
    <section class="form-alert show success" role="status">@successMessage</section>
}

<section class="page-intro">
    <div>
        <h2>Expensas</h2>
        <p>Gestion de liquidaciones por consorcio y periodo.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Expensas" asp-action="Generar" asp-route-consorcioId="@Model.ConsorcioId" asp-route-periodo="@Model.Periodo">Generar expensas</a>
</section>

<section class="dashboard-grid" aria-label="Resumen de expensas">
    <article class="app-card metric-card">
        <span>Liquidaciones</span>
        <strong>@Model.CantidadExpensas</strong>
        <small>Registros filtrados</small>
    </article>
    <article class="app-card metric-card">
        <span>Total emitido</span>
        <strong>@Model.TotalEmitido.ToString("C")</strong>
        <small>Monto liquidado</small>
    </article>
    <article class="app-card metric-card">
        <span>Total pagado</span>
        <strong>@Model.TotalPagado.ToString("C")</strong>
        <small>Pagos aprobados</small>
    </article>
    <article class="app-card metric-card">
        <span>Pendientes</span>
        <strong>@Model.Pendientes</strong>
        <small>Expensas por cobrar</small>
    </article>
</section>

<section class="app-card filter-card" aria-label="Filtros de expensas">
    <form method="get" asp-action="Index">
        <div class="form-grid">
            <div>
                <label class="form-label" for="consorcioId">Consorcio</label>
                <select class="form-select" id="consorcioId" name="consorcioId">
                    <option value="">Todos</option>
                    @foreach (var consorcio in Model.Consorcios)
                    {
                        if (Model.ConsorcioId == consorcio.Id)
                        {
                            <option value="@consorcio.Id" selected>@consorcio.Nombre</option>
                        }
                        else
                        {
                            <option value="@consorcio.Id">@consorcio.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label" for="periodo">Periodo</label>
                <input class="form-control" id="periodo" name="periodo" type="month" value="@Model.Periodo" />
            </div>
            <div>
                <label class="form-label" for="estado">Estado</label>
                <select class="form-select" id="estado" name="estado">
                    <option value="">Todos</option>
                    @foreach (var estado in Enum.GetValues<EstadoExpensa>())
                    {
                        if (Model.Estado == estado)
                        {
                            <option value="@estado" selected>@estado</option>
                        }
                        else
                        {
                            <option value="@estado">@estado</option>
                        }
                    }
                </select>
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
                <a class="btn btn-outline-secondary" asp-controller="Expensas" asp-action="Index">Limpiar</a>
            </div>
        </div>
    </form>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Liquidaciones generadas</h3>
        <span class="status-badge">@Model.CantidadExpensas registradas</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Periodo</th>
                    <th>Consorcio</th>
                    <th>UF</th>
                    <th>Propietario</th>
                    <th>Monto</th>
                    <th>Vencimiento</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Expensas.Any())
                {
                    <tr>
                        <td colspan="8">No hay expensas que coincidan con los filtros seleccionados.</td>
                    </tr>
                }
                else
                {
                    @foreach (var expensa in Model.Expensas)
                    {
                        <tr>
                            <td>@expensa.Periodo</td>
                            <td>@expensa.UnidadFuncional.Consorcio.Nombre</td>
                            <td>@expensa.UnidadFuncional.NumeroUF</td>
                            <td>@expensa.UnidadFuncional.NombrePropietario</td>
                            <td>@expensa.MontoTotal.ToString("C")</td>
                            <td>@expensa.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                            <td><span class="status-badge @EstadoClass(expensa.Estado)">@expensa.Estado</span></td>
                            <td>
                                <div class="table-actions">
                                    <a asp-controller="Expensas" asp-action="Details" asp-route-id="@expensa.Id" asp-route-returnUrl="@Url.Action("Index", "Expensas")">Ver detalle</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
