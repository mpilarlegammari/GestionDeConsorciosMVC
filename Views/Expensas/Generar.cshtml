@model GenerarExpensasViewModel
@{
    ViewData["Title"] = "Generar expensas";
    ViewData["Role"] = "Administrador";
}

@functions {
    private static string CategoriaClass(string? categoria) => categoria?.Trim() switch
    {
        "Limpieza" => "success",
        "Mantenimiento" => "warning",
        "Seguridad" => "neutral",
        _ => string.Empty
    };
}

<section class="page-intro">
    <div>
        <h2>Generar expensas</h2>
        <p>Crea las liquidaciones mensuales para un consorcio.</p>
    </div>
    <span class="status-badge">Backend</span>
</section>

@if (TempData["Error"] is string errorMessage)
{
    <section class="form-alert show" role="alert">@errorMessage</section>
}

<form asp-action="Generar" method="post" data-expensas-form data-real-submit>
    @Html.AntiForgeryToken()
    <section class="app-card section-card">
        <div class="app-card-title">
            <h3>Datos de generacion</h3>
            <span class="status-badge">Persistencia activa</span>
        </div>

        <div class="form-grid">
            <div>
                <label class="form-label" asp-for="ConsorcioId">Consorcio</label>
                <select class="form-select" asp-for="ConsorcioId" data-expensas-required>
                    <option value="">Seleccionar consorcio</option>
                    @foreach (var consorcio in Model.Consorcios)
                    {
                        if (Model.ConsorcioId == consorcio.Id)
                        {
                            <option value="@consorcio.Id" selected>@consorcio.Nombre (@consorcio.UnidadesFuncionales.Count UF)</option>
                        }
                        else
                        {
                            <option value="@consorcio.Id">@consorcio.Nombre (@consorcio.UnidadesFuncionales.Count UF)</option>
                        }
                    }
                </select>
                <span class="field-validation" asp-validation-for="ConsorcioId" data-error-for="ConsorcioId"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Periodo"></label>
                <input class="form-control" asp-for="Periodo" type="month" data-expensas-required />
                <span class="field-validation" asp-validation-for="Periodo" data-error-for="Periodo"></span>
            </div>
            <div>
                <label class="form-label" asp-for="FechaEmision">Fecha de emision</label>
                <input class="form-control" asp-for="FechaEmision" type="date" data-expensas-required />
                <span class="field-validation" asp-validation-for="FechaEmision" data-error-for="FechaEmision"></span>
            </div>
            <div>
                <label class="form-label" asp-for="FechaVencimiento">Fecha de vencimiento</label>
                <input class="form-control" asp-for="FechaVencimiento" type="date" data-expensas-required />
                <span class="field-validation" asp-validation-for="FechaVencimiento" data-error-for="FechaVencimiento"></span>
            </div>
            <div>
                <label class="form-label" asp-for="CriterioDistribucion">Criterio de distribucion</label>
                <select class="form-select" asp-for="CriterioDistribucion" data-expensas-required>
                    <option value="">Seleccionar criterio</option>
                    @if (Model.CriterioDistribucion == "Partes iguales por UF")
                    {
                        <option value="Partes iguales por UF" selected>Partes iguales por UF</option>
                    }
                    else
                    {
                        <option value="Partes iguales por UF">Partes iguales por UF</option>
                    }
                </select>
                <span class="field-validation" asp-validation-for="CriterioDistribucion" data-error-for="CriterioDistribucion"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" asp-for="Observaciones"></label>
                <textarea class="form-control" asp-for="Observaciones" rows="4" placeholder="Notas internas para la liquidacion."></textarea>
            </div>
        </div>

        <p class="form-note">Se toma el total de gastos del periodo y se divide en partes iguales entre las UF del consorcio.</p>
        <div class="form-summary" data-expensas-summary></div>
    </section>

    <section class="dashboard-grid" aria-label="Resumen de generacion">
        <article class="app-card metric-card">
            <span>Gastos incluidos</span>
            <strong>@Model.Gastos.Count</strong>
            <small>Del periodo seleccionado</small>
        </article>
        <article class="app-card metric-card">
            <span>Total gastos</span>
            <strong>@Model.TotalGastos.ToString("C")</strong>
            <small>Base de calculo</small>
        </article>
        <article class="app-card metric-card">
            <span>Unidades</span>
            <strong>@Model.CantidadUnidades</strong>
            <small>UF del consorcio</small>
        </article>
        <article class="app-card metric-card">
            <span>Monto por UF</span>
            <strong>@Model.MontoPorUnidad.ToString("C")</strong>
            <small>Distribucion simple</small>
        </article>
    </section>

    <section class="app-card section-card">
        <div class="app-card-title">
            <h3>Gastos incluidos en la liquidacion</h3>
            <span class="status-badge">@Model.TotalGastos.ToString("C")</span>
        </div>
        <div class="table-responsive">
            <table class="table table-clean">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Concepto</th>
                        <th>Categoria</th>
                        <th>Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Gastos.Any())
                    {
                        <tr>
                            <td colspan="4">Selecciona un consorcio y periodo con gastos cargados para generar expensas.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var gasto in Model.Gastos)
                        {
                            <tr>
                                <td>@gasto.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@gasto.Concepto</td>
                                <td><span class="status-badge @CategoriaClass(gasto.Categoria.ToString())">@gasto.Categoria</span></td>
                                <td>@gasto.Monto.ToString("C")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-controller="Expensas" asp-action="Index">Cancelar</a>
            <button class="btn btn-primary" type="submit">Generar expensas</button>
        </div>
    </section>
</form>
