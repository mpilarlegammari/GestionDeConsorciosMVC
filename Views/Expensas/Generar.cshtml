@{
    ViewData["Title"] = "Generar Expensas";
    ViewData["Role"] = "Administrador";
}

@* TODO backend: reemplazar datos mock por ViewModel. *@
@* TODO backend: obtener consorcios administrados por el usuario. *@
@* TODO backend: obtener gastos del período seleccionado. *@
@* TODO backend: calcular total de gastos. *@
@* TODO backend: calcular monto por UF según gastos del período. *@
