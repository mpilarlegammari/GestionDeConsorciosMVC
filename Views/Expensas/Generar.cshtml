@{
    ViewData["Title"] = "Generar expensas";
    ViewData["Role"] = "Administrador";
    var consorcios = ViewBag.Consorcios as IEnumerable<Consorcio> ?? Enumerable.Empty<Consorcio>();
    var gastos = ViewBag.Gastos as IEnumerable<Gasto> ?? Enumerable.Empty<Gasto>();
    var totalGastos = gastos.Sum(g => g.Monto);
}

@functions {
    private static string CategoriaClass(CategoriaGasto categoria) => categoria switch
    {
        CategoriaGasto.Limpieza => "success",
        CategoriaGasto.Mantenimiento => "warning",
        CategoriaGasto.Seguridad => "neutral",
        _ => string.Empty
    };
}

<section class="page-intro">
    <div>
        <h2>Generar expensas</h2>
        <p>Crea las liquidaciones mensuales para un consorcio.</p>
    </div>
    <span class="status-badge">Backend</span>
</section>

@if (TempData["Error"] is string errorMessage)
{
    <section class="form-alert show" role="alert">@errorMessage</section>
}

<form asp-action="Generar" method="post" data-expensas-form data-real-submit>
    @Html.AntiForgeryToken()
    <section class="app-card section-card">
        <div class="app-card-title">
            <h3>Datos de generacion</h3>
            <span class="status-badge">Persistencia activa</span>
        </div>

        <div class="form-grid">
            <div>
                <label class="form-label" for="ConsorcioId">Consorcio</label>
                <select class="form-select" id="ConsorcioId" name="ConsorcioId" data-expensas-required>
                    <option value="">Seleccionar consorcio</option>
                    @foreach (var consorcio in consorcios)
                    {
                        <option value="@consorcio.Id">@consorcio.Nombre (@consorcio.UnidadesFuncionales.Count UF)</option>
                    }
                </select>
                <span class="field-validation" data-error-for="ConsorcioId"></span>
            </div>
            <div>
                <label class="form-label" for="Periodo">Periodo</label>
                <input class="form-control" id="Periodo" name="Periodo" type="month" value="@DateTime.Today.ToString("yyyy-MM")" data-expensas-required />
                <span class="field-validation" data-error-for="Periodo"></span>
            </div>
            <div>
                <label class="form-label" for="FechaEmision">Fecha de emision</label>
                <input class="form-control" id="FechaEmision" name="FechaEmision" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" data-expensas-required />
                <span class="field-validation" data-error-for="FechaEmision"></span>
            </div>
            <div>
                <label class="form-label" for="FechaVencimiento">Fecha de vencimiento</label>
                <input class="form-control" id="FechaVencimiento" name="FechaVencimiento" type="date" value="@DateTime.Today.AddDays(10).ToString("yyyy-MM-dd")" data-expensas-required />
                <span class="field-validation" data-error-for="FechaVencimiento"></span>
            </div>
            <div>
                <label class="form-label" for="CriterioDistribucion">Criterio de distribucion</label>
                <select class="form-select" id="CriterioDistribucion" name="CriterioDistribucion" data-expensas-required>
                    <option value="">Seleccionar criterio</option>
                    <option selected>Partes iguales por UF</option>
                </select>
                <span class="field-validation" data-error-for="CriterioDistribucion"></span>
            </div>
            <div class="form-span-2">
                <label class="form-label" for="Observaciones">Observaciones</label>
                <textarea class="form-control" id="Observaciones" name="Observaciones" rows="4" placeholder="Notas internas para la liquidacion."></textarea>
            </div>
        </div>

        <p class="form-note">Se toma el total de gastos del periodo y se divide en partes iguales entre las UF del consorcio.</p>
        <div class="form-summary" data-expensas-summary></div>
    </section>

    <section class="app-card section-card">
        <div class="app-card-title">
            <h3>Gastos incluidos en la liquidacion</h3>
            <span class="status-badge">@totalGastos.ToString("C")</span>
        </div>
        <div class="table-responsive">
            <table class="table table-clean">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Concepto</th>
                        <th>Categoria</th>
                        <th>Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!gastos.Any())
                    {
                        <tr>
                            <td colspan="4">Selecciona un consorcio y periodo con gastos cargados para generar expensas.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var gasto in gastos)
                        {
                            <tr>
                                <td>@gasto.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@gasto.Concepto</td>
                                <td><span class="status-badge @CategoriaClass(gasto.Categoria)">@gasto.Categoria</span></td>
                                <td>@gasto.Monto.ToString("C")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-controller="Expensas" asp-action="Index">Cancelar</a>
            <button class="btn btn-primary" type="submit">Generar expensas</button>
        </div>
    </section>
</form>
