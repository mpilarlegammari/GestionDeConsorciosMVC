<section class="page-intro">
    <div>
        <h2>Mis Expensas</h2>
        <p>Consultá tus liquidaciones y estado de pagos.</p>
    </div>
    <span class="status-badge warning">Pendiente</span>
</section>

<section class="app-card expense-card">
    <div>
        <span class="card-kicker">Período actual</span>
        <h3>Mayo 2026</h3>
        <p>Vencimiento: 10/06/2026</p>
    </div>
    <div class="expense-summary">
        <div>
            <span class="card-kicker">Estado</span>
            <strong><span class="status-badge warning">Pendiente</span></strong>
        </div>
        <div>
            <span class="card-kicker">Monto</span>
            <strong>$85.000</strong>
        </div>
    </div>
    <div class="button-group">
        <a class="btn btn-outline-primary" asp-controller="Expensas" asp-action="Details" asp-route-id="105">Ver detalle</a>
        <a class="btn btn-primary" href="/Pagos/InformarPago">Informar pago</a>
        <a class="btn btn-outline-secondary" href="#">Descargar liquidación</a>
    </div>
</section>

<section class="app-card filter-card" aria-label="Filtros de mis expensas">
    <form method="get" asp-action="MisExpensas">
        <div class="form-grid">
            <div>
                <label class="form-label" for="mes">Mes</label>
                <select class="form-select" id="mes" name="mes">
                    <option value="5">Mayo</option>
                    <option value="4">Abril</option>
                    <option value="3">Marzo</option>
                    <option value="2">Febrero</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="anio">Año</label>
                <select class="form-select" id="anio" name="anio">
                    <option>2026</option>
                    <option>2025</option>
                </select>
            </div>
            <div>
                <label class="form-label" for="estado">Estado</label>
                <select class="form-select" id="estado" name="estado">
                    <option value="">Todos</option>
                    <option>Pendiente</option>
                    <option>Pagada</option>
                    <option>Vencida</option>
                </select>
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit">Filtrar</button>
            </div>
        </div>
    </form>
</section>

<section class="dashboard-grid">
    <article class="app-card metric-card">
        <span>Expensas pagadas</span>
        <strong>14</strong>
        <small>Historial disponible</small>
    </article>
    <article class="app-card metric-card">
        <span>Expensas pendientes</span>
        <strong>2</strong>
        <small>Requieren seguimiento</small>
    </article>
    <article class="app-card metric-card">
        <span>Total abonado este año</span>
        <strong>$980.000</strong>
        <small>Enero a mayo</small>
    </article>
    <article class="app-card metric-card">
        <span>Último pago informado</span>
        <strong>12/05</strong>
        <small>Transferencia bancaria</small>
    </article>
</section>

