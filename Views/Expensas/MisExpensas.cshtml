@{
    ViewData["Title"] = "Mis Expensas";
    ViewData["Role"] = "Propietario";
}

@* TODO backend: reemplazar datos mock por Model.Expensas. *@
@* TODO backend: obtener expensas desde usuario autenticado. *@
@* TODO backend: calcular estado automáticamente. *@
