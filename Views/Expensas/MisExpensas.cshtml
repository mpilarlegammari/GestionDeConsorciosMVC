@model IEnumerable<Expensa>
@{
    ViewData["Title"] = "Mis Expensas";
    ViewData["Role"] = "Propietario";
    var expensaActual = Model.OrderByDescending(e => e.FechaEmision).FirstOrDefault();
}

@functions {
    private static string EstadoClass(EstadoExpensa estado) => estado switch
    {
        EstadoExpensa.Pagada => "success",
        EstadoExpensa.Pendiente => "warning",
        EstadoExpensa.Vencida => "danger",
        _ => "neutral"
    };
}

<section class="page-intro">
    <div>
        <h2>Mis Expensas</h2>
        <p>Consulta tus liquidaciones y estado de pagos.</p>
    </div>
    <span class="status-badge">Backend</span>
</section>

@if (expensaActual is not null)
{
    <section class="app-card expense-card">
        <div>
            <span class="card-kicker">Periodo actual</span>
            <h3>@expensaActual.Periodo</h3>
            <p>Vencimiento: @expensaActual.FechaVencimiento.ToString("dd/MM/yyyy")</p>
        </div>
        <div class="expense-summary">
            <div>
                <span class="card-kicker">Estado</span>
                <strong><span class="status-badge @EstadoClass(expensaActual.Estado)">@expensaActual.Estado</span></strong>
            </div>
            <div>
                <span class="card-kicker">Monto</span>
                <strong>@expensaActual.MontoTotal.ToString("C")</strong>
            </div>
        </div>
        <div class="button-group">
            <a class="btn btn-outline-primary" asp-controller="Expensas" asp-action="Details" asp-route-id="@expensaActual.Id" asp-route-returnUrl="@Url.Action("MisExpensas", "Expensas")">Ver detalle</a>
            <a class="btn btn-primary" href="/Pagos/InformarPago">Informar pago</a>
        </div>
    </section>
}

<section class="dashboard-grid">
    <article class="app-card metric-card">
        <span>Expensas pagadas</span>
        <strong>@Model.Count(e => e.Estado == EstadoExpensa.Pagada)</strong>
        <small>Historial disponible</small>
    </article>
    <article class="app-card metric-card">
        <span>Expensas pendientes</span>
        <strong>@Model.Count(e => e.Estado == EstadoExpensa.Pendiente)</strong>
        <small>Requieren seguimiento</small>
    </article>
    <article class="app-card metric-card">
        <span>Total emitido</span>
        <strong>@Model.Sum(e => e.MontoTotal).ToString("C")</strong>
        <small>Segun datos actuales</small>
    </article>
    <article class="app-card metric-card">
        <span>Ultima emision</span>
        <strong>@(expensaActual is null ? "-" : expensaActual.FechaEmision.ToString("dd/MM"))</strong>
        <small>@(expensaActual is null ? "Sin datos" : expensaActual.FechaEmision.Year)</small>
    </article>
</section>

<section class="app-card section-card">
    <div class="app-card-title">
        <h3>Historial de expensas</h3>
        <span class="status-badge">@Model.Count() registradas</span>
    </div>
    <div class="table-responsive">
        <table class="table table-clean">
            <thead>
                <tr>
                    <th>Periodo</th>
                    <th>Unidad</th>
                    <th>Fecha emision</th>
                    <th>Vencimiento</th>
                    <th>Monto</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7">Todavia no hay expensas generadas.</td>
                    </tr>
                }
                else
                {
                    @foreach (var expensa in Model)
                    {
                        <tr>
                            <td>@expensa.Periodo</td>
                            <td>@expensa.UnidadFuncional.NumeroUF</td>
                            <td>@expensa.FechaEmision.ToString("dd/MM/yyyy")</td>
                            <td>@expensa.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                            <td>@expensa.MontoTotal.ToString("C")</td>
                            <td><span class="status-badge @EstadoClass(expensa.Estado)">@expensa.Estado</span></td>
                            <td>
                                <div class="table-actions">
                                    <a asp-controller="Expensas" asp-action="Details" asp-route-id="@expensa.Id" asp-route-returnUrl="@Url.Action("MisExpensas", "Expensas")">Ver detalle</a>
                                    @if (expensa.Estado != EstadoExpensa.Pagada)
                                    {
                                        <a href="/Pagos/InformarPago">Informar pago</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
